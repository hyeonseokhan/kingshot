---
import GuideLayout from '@/layouts/GuideLayout.astro';
import {
  getGuidesByCategory,
  getEnIndexByCategory,
  getGuideEn,
  entryToSlug,
  buildNavItems,
  type GuideEntry,
} from '@/lib/guides';

export async function getStaticPaths() {
  const guides = await getGuidesByCategory('events');
  const enIndex = await getEnIndexByCategory('events');
  return guides.map((entry) => ({
    params: { slug: entryToSlug(entry) },
    props: { entry, all: guides, enIndex },
  }));
}

interface Props {
  entry: GuideEntry;
  all: GuideEntry[];
  enIndex: Record<string, GuideEntry>;
}

const { entry, all, enIndex } = Astro.props;
const slug = entryToSlug(entry);
const { Content: ContentKo, headings: headingsKo } = await entry.render();

const enEntry = await getGuideEn(entry);
const enRendered = enEntry ? await enEntry.render() : null;
const ContentEn = enRendered?.Content;
const headingsEn = enRendered?.headings ?? [];

const navItems = buildNavItems(all, 'events', slug, enIndex);
---

<GuideLayout
  title={`${entry.data.title} — PNX 연맹`}
  description={`PNX 연맹 이벤트 가이드 — ${entry.data.title}`}
  navHeader="목차"
  navHeaderKey="common.contents"
  navItems={navItems}
  headings={headingsKo}
  hasEn={!!ContentEn}
  headingsEn={headingsEn}
>
  {ContentEn && <ContentKo slot="ko" />}
  {ContentEn && <ContentEn slot="en" />}
  {!ContentEn && <ContentKo />}
</GuideLayout>
