---
import GuideLayout from '@/layouts/GuideLayout.astro';
import { getGuidesByCategory, entryToSlug, buildNavItems } from '@/lib/guides';

const guides = await getGuidesByCategory('beginner');
const first = guides[0];
if (!first) {
  throw new Error('beginner 카테고리에 가이드가 없습니다.');
}
const firstSlug = entryToSlug(first);
const { Content, headings } = await first.render();
const navItems = buildNavItems(guides, 'beginner', firstSlug);
---

<GuideLayout
  title={`${first.data.title} — PNX 연맹`}
  description="PNX 연맹 입문 가이드"
  navHeader="목차"
  navItems={navItems}
  headings={headings}
>
  <Content />
</GuideLayout>
