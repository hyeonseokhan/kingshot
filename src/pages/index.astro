---
import GuideLayout from '@/layouts/GuideLayout.astro';

// Phase 3 에서 Astro Content Collection 으로부터 첫 입문 가이드를 렌더링하도록 교체.
const navItems: Array<{ title: string; path: string; active?: boolean }> = [];
---

<GuideLayout
  title="입문 가이드 — PNX 연맹"
  description="PNX 연맹 입문 가이드"
  navHeader="목차"
  navItems={navItems}
>
  <h1>입문 가이드</h1>
  <p>
    Phase 3 (가이드 마이그레이션) 에서 <code>_guides/beginner/</code> 의 마크다운 7편이
    <code>src/content/guides/beginner/</code> 으로 이식되어 이 자리에 렌더링된다.
  </p>
</GuideLayout>
