---
import GuideLayout from '@/layouts/GuideLayout.astro';
import {
  getGuidesByCategory,
  getEnIndexByCategory,
  getGuideEn,
  entryToSlug,
  buildNavItems,
} from '@/lib/guides';

const guides = await getGuidesByCategory('beginner');
const enIndex = await getEnIndexByCategory('beginner');
const first = guides[0];
if (!first) {
  throw new Error('beginner 카테고리에 가이드가 없습니다.');
}
const firstSlug = entryToSlug(first);
const { Content: ContentKo, headings: headingsKo } = await first.render();

const enEntry = await getGuideEn(first);
const enRendered = enEntry ? await enEntry.render() : null;
const ContentEn = enRendered?.Content;
const headingsEn = enRendered?.headings ?? [];

const navItems = buildNavItems(guides, 'beginner', firstSlug, enIndex);
---

<GuideLayout
  title={`${first.data.title} — PNX 연맹`}
  description="PNX 연맹 입문 가이드"
  navHeader="목차"
  navHeaderKey="common.contents"
  navItems={navItems}
  headings={headingsKo}
  hasEn={!!ContentEn}
  headingsEn={headingsEn}
>
  {ContentEn ? (
    <>
      <ContentKo slot="ko" />
      <ContentEn slot="en" />
    </>
  ) : (
    <ContentKo />
  )}
</GuideLayout>
