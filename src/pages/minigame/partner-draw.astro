---
import AppLayout from '@/layouts/AppLayout.astro';
import AuthDialog from '@/components/AuthDialog.astro';
import { tabs, findActiveSubmenu } from '@/data/navigation';
// 공통 컴포넌트 스타일은 BaseLayout 에서 자동 import. 게임 전용만 추가.
import '@/styles/minigame.css';

const minigame = tabs.find((t) => t.id === 'minigame')!;
const active = findActiveSubmenu(minigame, Astro.url.pathname);
const navItems = minigame.submenus!.map((s) => ({
  title: s.title,
  path: s.path,
  active: active?.id === s.id,
}));
---

<AppLayout
  title="운명의 파트너 — PNX 연맹"
  description="슬롯머신 파트너 추첨"
  navHeader="미니게임"
  navItems={navItems}
>
  <AuthDialog />

  <div class="manage-page" id="page-partner-draw">
    <div class="members-header">
      <h1>운명의 파트너</h1>
      <div class="tm-launch-user" id="pd-user" style="display:none">
        <span class="tm-launch-user-label">인증됨</span>
        <strong id="pd-user-name">-</strong>
        <span class="tm-launch-user-id" id="pd-user-id"></span>
        <button class="tm-launch-user-logout" id="pd-user-logout" type="button">전환</button>
      </div>
    </div>

    <div class="page-intro">
      <p><strong>🎰 오늘의 파티원, 운명에 맡겨봐요</strong></p>
      <ul>
        <li>본인 포함 <strong>2~4명</strong> 인원 선택 — 본인은 자동 제외</li>
        <li>슬롯이 한 명씩 멈출 때까지 기다리세요</li>
      </ul>
    </div>

    <!-- 추첨 카드 -->
    <div class="pd-card">
      <div class="pd-card-title">파티 인원</div>
      <div class="pd-card-meta">본인 포함 <span id="pd-stepper-value">4</span>명</div>
      <div class="pd-stepper">
        <button class="pd-stepper-btn" id="pd-stepper-minus" type="button" aria-label="감소">−</button>
        <button class="pd-stepper-btn" id="pd-stepper-plus" type="button" aria-label="증가">+</button>
      </div>
      <button class="pd-draw-btn" id="pd-draw-btn" type="button">오늘의 운명의 파트너</button>
    </div>

    <!-- 슬롯머신 결과 카드 -->
    <div class="pd-result" id="pd-result" style="display:none">
      <div class="pd-result-card" id="pd-result-card">
        <div class="pd-result-header">
          <div class="pd-result-title">🎉 오늘의 깐부</div>
          <div class="pd-result-subtitle">바이킹 같이 가요!</div>
        </div>
        <div class="pd-slots" id="pd-slots"></div>
        <div class="pd-result-footer">
          <span class="pd-result-brand">PNX · Kingshot</span>
          <span id="pd-result-date"></span>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  import '@/scripts/pages/tile-match-auth';
  import { initPartnerDraw } from '@/scripts/pages/partner-draw';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPartnerDraw);
  } else {
    initPartnerDraw();
  }
</script>
