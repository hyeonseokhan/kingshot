---
import AppLayout from '@/layouts/AppLayout.astro';
import { tabs, findActiveSubmenu } from '@/data/navigation';
import { SLOT_LABEL } from '@/lib/balance';
import '@/styles/minigame.css';

const minigame = tabs.find((t) => t.id === 'minigame')!;
const active = findActiveSubmenu(minigame, Astro.url.pathname);
const navItems = minigame.submenus!.map((s) => ({
  title: s.title,
  path: s.path,
  active: active?.id === s.id,
}));

// 좌우 3:3 레이아웃 — 게임 원본 캐릭터 둘러싸는 패턴 그대로.
// 행 인덱스(1~3)는 CSS 의 절대 좌표 매핑에 사용.
const SLOT_LAYOUT = [
  { slot: 'crown',    side: 'left',  row: 1 },
  { slot: 'top',      side: 'left',  row: 2 },
  { slot: 'ring',     side: 'left',  row: 3 },
  { slot: 'necklace', side: 'right', row: 1 },
  { slot: 'bottom',   side: 'right', row: 2 },
  { slot: 'staff',    side: 'right', row: 3 },
] as const;
---

<AppLayout
  title="장비 강화 — PNX 연맹"
  description="크리스탈로 장비를 강화해 전투력을 올리세요"
  navHeader="미니게임"
  navItems={navItems}
>
  <div class="manage-page" id="page-equipment">
    <div class="members-header">
      <h1>장비 강화</h1>
    </div>

    <!-- 비인증 안내 -->
    <div class="eq-auth-prompt" id="eq-auth-prompt" style="display:none">
      헤더의 <strong>로그인</strong> 버튼으로 인증한 뒤 강화할 수 있어요.
    </div>

    <!-- 캐릭터 중심 캔버스 — 모바일 폰 폼팩터 비율 (3:4) -->
    <div class="eq-stage" id="eq-stage" data-state="loading">
      <!-- 가운데 아바타 -->
      <div class="eq-avatar">
        <img class="eq-avatar-img" id="eq-avatar-img" alt="" />
      </div>

      <!-- 6슬롯 — 좌우 3:3 절대 위치 -->
      {SLOT_LAYOUT.map(({ slot, side, row }) => (
        <button
          type="button"
          class={`eq-slot eq-slot-${side} eq-slot-row-${row}`}
          data-slot={slot}
          data-action="open-modal"
          aria-label={`${SLOT_LABEL[slot].name} 강화`}
        >
          <span class="eq-slot-badge" data-field="badge" hidden>+0</span>
          <img
            class="eq-slot-icon"
            src={SLOT_LABEL[slot].image}
            alt={SLOT_LABEL[slot].name}
            loading="lazy"
            decoding="async"
          />
        </button>
      ))}

      <!-- 하단: 장비 합산 전투력 -->
      <div class="eq-totalpower" id="eq-totalpower">
        <span class="eq-totalpower-icon">💎</span>
        <span class="eq-totalpower-value" id="eq-total-power">—</span>
        <span class="eq-totalpower-label">장비 총 전투력</span>
      </div>
    </div>

    <!-- 강화 모달 (네이티브 dialog) -->
    <dialog class="eq-modal" id="eq-modal" aria-labelledby="eq-modal-title">
      <div class="eq-modal-card">
        <header class="eq-modal-head">
          <img
            class="eq-modal-icon"
            data-field="icon"
            src="/images/items/crown.png"
            alt=""
          />
          <div class="eq-modal-title-wrap">
            <strong id="eq-modal-title" data-field="name">월계관</strong>
            <span class="eq-modal-level" data-field="level-text">+0 단계</span>
          </div>
          <button
            type="button"
            class="eq-modal-close"
            data-action="close-modal"
            aria-label="닫기"
          >×</button>
        </header>

        <section class="eq-modal-stats">
          <div class="eq-modal-row">
            <span class="eq-modal-row-label">현재 전투력</span>
            <strong class="eq-modal-row-value" data-field="cur-power">+0</strong>
          </div>
          <div class="eq-modal-row eq-modal-row-after" data-field="after-row">
            <span class="eq-modal-row-label">강화 후</span>
            <strong class="eq-modal-row-value">
              <span data-field="next-power">+0</span>
              <em data-field="delta">(↑0)</em>
            </strong>
          </div>
        </section>

        <section class="eq-modal-cost" data-field="cost-section">
          <div class="eq-modal-row">
            <span class="eq-modal-row-label">💎 비용</span>
            <strong class="eq-modal-row-value" data-field="cost">0</strong>
          </div>
          <div class="eq-modal-row">
            <span class="eq-modal-row-label">성공 확률</span>
            <strong class="eq-modal-row-value" data-field="rate">0%</strong>
          </div>
        </section>

        <p class="eq-modal-note" data-field="note">실패해도 등급은 유지 — 크리스탈만 소모</p>

        <button
          type="button"
          class="eq-modal-cta"
          id="eq-modal-cta"
          data-action="enhance"
          disabled
        >강화 시도</button>

        <div class="eq-modal-result" data-field="result"></div>
      </div>
    </dialog>
  </div>
</AppLayout>

<script>
  import '@/scripts/pages/tile-match-auth';
  import { initEquipment } from '@/scripts/pages/equipment';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEquipment);
  } else {
    initEquipment();
  }
</script>
