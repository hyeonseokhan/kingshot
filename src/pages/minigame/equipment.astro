---
import AppLayout from '@/layouts/AppLayout.astro';
import { tabs, findActiveSubmenu } from '@/data/navigation';
import { SLOT_LABEL } from '@/lib/balance';
import '@/styles/minigame.css';

const minigame = tabs.find((t) => t.id === 'minigame')!;
const active = findActiveSubmenu(minigame, Astro.url.pathname);
const navItems = minigame.submenus!.map((s) => ({
  title: s.title,
  path: s.path,
  active: active?.id === s.id,
}));

// 좌우 3:3 레이아웃 — 게임 원본 캐릭터 둘러싸는 패턴 그대로.
// 행 인덱스(1~3)는 CSS 의 절대 좌표 매핑에 사용.
const SLOT_LAYOUT = [
  { slot: 'crown',    side: 'left',  row: 1 },
  { slot: 'top',      side: 'left',  row: 2 },
  { slot: 'ring',     side: 'left',  row: 3 },
  { slot: 'necklace', side: 'right', row: 1 },
  { slot: 'bottom',   side: 'right', row: 2 },
  { slot: 'staff',    side: 'right', row: 3 },
] as const;
---

<AppLayout
  title="장비 강화 — PNX 연맹"
  description="크리스탈로 장비를 강화해 전투력을 올리세요"
  navHeader="미니게임"
  navItems={navItems}
>
  <div class="manage-page" id="page-equipment">
    <div class="members-header">
      <h1>장비 강화</h1>
    </div>

    <div class="page-intro">
      <p><strong>💎 크리스탈로 6부위 장비를 강화해 전투력을 올리세요</strong></p>
      <ul>
        <li>등급: <strong>일반(+0)</strong> · 고급(+1~9) · 희귀(+10~24) · 영웅(+25~44) · 레전드(+45~69) · <strong>신화(+70~100)</strong></li>
        <li>1~2단계: 100% 성공 / 3단계 이후: 확률 강화 (실패해도 등급 유지)</li>
        <li>크리스탈은 타일매치 stage 클리어 보상 — <strong>stage 46+ 는 매 클리어마다 100 반복 파밍</strong></li>
      </ul>
      <p class="page-intro-action">
        장비 강화 등급별 효과를 미리 살펴보세요!
        <button type="button" class="tier-preview-trigger" id="tier-preview-trigger">✨ 효과 미리보기</button>
      </p>
    </div>

    <!-- 비인증 안내 -->
    <div class="eq-auth-prompt" id="eq-auth-prompt" style="display:none">
      헤더의 <strong>로그인</strong> 버튼으로 인증한 뒤 강화할 수 있어요.
    </div>

    <!-- 캐릭터 중심 캔버스 — 모바일 폰 폼팩터 비율 (3:4) -->
    <div class="eq-stage" id="eq-stage" data-state="loading">
      <!-- 가운데 아바타 -->
      <div class="eq-avatar">
        <span class="eq-avatar-glow" aria-hidden="true"></span>
        <img class="eq-avatar-img" id="eq-avatar-img" alt="" />
      </div>

      <!-- 6슬롯 — 좌우 3:3 절대 위치 -->
      {SLOT_LAYOUT.map(({ slot, side, row }) => (
        <button
          type="button"
          class={`eq-slot eq-slot-${side} eq-slot-row-${row} eq-slot-tier-common`}
          data-slot={slot}
          data-action="open-modal"
          aria-label={`${SLOT_LABEL[slot].name} 강화`}
        >
          <span class="eq-slot-badge" data-field="badge" hidden>+0</span>
          <img
            class="eq-slot-icon"
            src={SLOT_LABEL[slot].image}
            alt={SLOT_LABEL[slot].name}
            loading="lazy"
            decoding="async"
          />
        </button>
      ))}

      <!-- 하단: 장비 합산 전투력 — "총 전투력:    +0" -->
      <div class="eq-totalpower" id="eq-totalpower">
        <span class="eq-totalpower-label">총 전투력:</span>
        <span class="eq-totalpower-value" id="eq-total-power">+0</span>
      </div>
    </div>

    <!-- 강화 모달 (네이티브 dialog) -->
    <dialog class="eq-modal" id="eq-modal" aria-labelledby="eq-modal-title">
      <!-- 모달 카드 위쪽에 떠오르는 결과 토스트 (dialog 내부라 top layer 안) -->
      <div id="eq-result-toast" class="eq-result-toast" data-active="false" aria-live="polite"></div>
      <div class="eq-modal-card">
        <header class="eq-modal-head">
          <!-- 슬롯 미니어처 — 강화 단계의 등급 색상 + 배지 동일 적용 -->
          <div class="eq-slot eq-modal-slot-mini eq-slot-tier-common" data-field="icon-wrap">
            <span class="eq-slot-badge" data-field="modal-badge" hidden>+0</span>
            <img
              class="eq-slot-icon"
              data-field="icon"
              src="/images/items/crown.png"
              alt=""
            />
          </div>
          <div class="eq-modal-title-wrap">
            <strong id="eq-modal-title" data-field="name">월계관</strong>
            <span class="eq-modal-level" data-field="level-text">+0 단계</span>
          </div>
          <button
            type="button"
            class="eq-modal-close"
            data-action="close-modal"
            aria-label="닫기"
          >×</button>
        </header>

        <section class="eq-modal-stats">
          <div class="eq-modal-row">
            <span class="eq-modal-row-label">현재 전투력</span>
            <strong class="eq-modal-row-value" data-field="cur-power">+0</strong>
          </div>
          <div class="eq-modal-row eq-modal-row-after" data-field="after-row">
            <span class="eq-modal-row-label">강화 후</span>
            <strong class="eq-modal-row-value">
              <span data-field="next-power">+0</span>
              <em data-field="delta">(↑0)</em>
            </strong>
          </div>
        </section>

        <section class="eq-modal-cost" data-field="cost-section">
          <div class="eq-modal-row">
            <span class="eq-modal-row-label">💎 비용</span>
            <strong class="eq-modal-row-value" data-field="cost">0</strong>
          </div>
          <div class="eq-modal-row">
            <span class="eq-modal-row-label">성공 확률</span>
            <strong class="eq-modal-row-value" data-field="rate">0%</strong>
          </div>
        </section>

        <p class="eq-modal-note" data-field="note">실패해도 등급은 유지 — 크리스탈만 소모</p>

        <button
          type="button"
          class="eq-modal-cta"
          id="eq-modal-cta"
          data-action="enhance"
          disabled
        >강화 시도</button>

        <div class="eq-modal-result" data-field="result"></div>
      </div>
    </dialog>

    <!-- 효과 미리보기 다이얼로그 — 6 등급 (일반~신화) 을 좌/우 화살표 + 스와이프 + dot 으로 전환 -->
    <dialog class="tier-preview-dialog" id="tier-preview-dialog" aria-labelledby="tier-preview-name">
      <div class="tier-preview-card">
        <header class="tier-preview-head">
          <div class="tier-preview-title">
            <strong class="tier-preview-name" id="tier-preview-name">일반</strong>
            <span class="tier-preview-level" id="tier-preview-level">+0</span>
          </div>
          <button type="button" class="tier-preview-close" id="tier-preview-close" aria-label="닫기">×</button>
        </header>

        <!-- 미리보기 stage — 실제 .eq-stage 와 동일 구조. is-readonly 로 슬롯 hover/active 차단 -->
        <div class="eq-stage tier-preview-stage is-readonly" id="tier-preview-stage">
          <div class="eq-avatar">
            <span class="eq-avatar-glow" aria-hidden="true"></span>
            <img class="eq-avatar-img" id="tier-preview-avatar" alt="" />
          </div>
          {SLOT_LAYOUT.map(({ slot, side, row }) => (
            <div
              class={`eq-slot eq-slot-${side} eq-slot-row-${row} eq-slot-tier-common`}
              data-tier-preview-slot={slot}
              aria-label={`${SLOT_LABEL[slot].name} (미리보기)`}
            >
              <span class="eq-slot-badge" data-tier-preview-field="badge" hidden>+0</span>
              <img
                class="eq-slot-icon"
                src={SLOT_LABEL[slot].image}
                alt={SLOT_LABEL[slot].name}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
          <div class="eq-totalpower">
            <span class="eq-totalpower-label">총 전투력:</span>
            <span class="eq-totalpower-value" id="tier-preview-total">+0</span>
          </div>
        </div>

        <!-- 하단 네비게이션: ‹  [● ○ ○ ○ ○ ○]  › -->
        <nav class="tier-preview-nav" aria-label="등급 전환">
          <button type="button" class="tier-preview-prev" id="tier-preview-prev" aria-label="이전 등급">‹</button>
          <div class="tier-preview-dots" id="tier-preview-dots" role="tablist" aria-label="등급 선택">
            <button type="button" class="tier-preview-dot active" data-tier-preview-idx="0" role="tab" aria-label="일반"></button>
            <button type="button" class="tier-preview-dot" data-tier-preview-idx="1" role="tab" aria-label="고급"></button>
            <button type="button" class="tier-preview-dot" data-tier-preview-idx="2" role="tab" aria-label="희귀"></button>
            <button type="button" class="tier-preview-dot" data-tier-preview-idx="3" role="tab" aria-label="영웅"></button>
            <button type="button" class="tier-preview-dot" data-tier-preview-idx="4" role="tab" aria-label="레전드"></button>
            <button type="button" class="tier-preview-dot" data-tier-preview-idx="5" role="tab" aria-label="신화"></button>
          </div>
          <button type="button" class="tier-preview-next" id="tier-preview-next" aria-label="다음 등급">›</button>
        </nav>
      </div>
    </dialog>
  </div>
</AppLayout>

<script>
  import '@/scripts/pages/tile-match-auth';
  import { initEquipment } from '@/scripts/pages/equipment';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEquipment);
  } else {
    initEquipment();
  }
</script>
