---
import AppLayout from '@/layouts/AppLayout.astro';
import { tabs, findActiveSubmenu } from '@/data/navigation';
import { SLOT_LABEL } from '@/lib/balance';
import RankingTable from '@/components/RankingTable.astro';
import '@/styles/minigame.css';

const minigame = tabs.find((t) => t.id === 'minigame')!;
const active = findActiveSubmenu(minigame, Astro.url.pathname);
const navItems = minigame.submenus!.map((s) => ({
  title: s.title,
  path: s.path,
  active: active?.id === s.id,
}));

// equipment 페이지와 동일한 슬롯 배치 — 좌우 3:3
const SLOT_LAYOUT = [
  { slot: 'crown',    side: 'left',  row: 1 },
  { slot: 'top',      side: 'left',  row: 2 },
  { slot: 'ring',     side: 'left',  row: 3 },
  { slot: 'necklace', side: 'right', row: 1 },
  { slot: 'bottom',   side: 'right', row: 2 },
  { slot: 'staff',    side: 'right', row: 3 },
] as const;
---

<AppLayout
  title="매칭 대결 — PNX 연맹"
  description="장비 강화한 power 로 다른 연맹원과 카드 대결"
  navHeader="미니게임"
  navItems={navItems}
>
  <div class="manage-page" id="page-pvp">
    <div class="members-header">
      <h1>매칭 대결</h1>
    </div>

    <div class="page-intro">
      <p><strong>⚔️ 장비 강화한 power 로 연맹원과 카드 대결을 펼치세요</strong></p>
      <ul>
        <li><strong>일일 5회</strong> 공격 (방어는 무제한). KST 자정 리셋</li>
        <li>5턴 대결 / HP 1000 / 카드 3종 — 공격·강화·방어</li>
        <li>승리 +200 / 패배 +50 크리스탈 (참가 보상)</li>
        <li>방어자는 자동 응전 — 비동기 PvP</li>
      </ul>
    </div>

    <!-- 비인증 안내 -->
    <div class="eq-auth-prompt" id="pvp-auth-prompt" style="display:none">
      헤더의 <strong>로그인</strong> 버튼으로 인증한 뒤 대결할 수 있어요.
    </div>

    <!-- view: matching (default) -->
    <section class="pvp-view" data-view="matching" id="pvp-view-matching">
      <div class="pvp-daily" id="pvp-daily-panel">
        <span class="pvp-daily-label">오늘 남은 공격</span>
        <strong class="pvp-daily-value" id="pvp-daily-remaining">—</strong>
        <span class="pvp-daily-max">/ 5</span>
      </div>

      <!-- 연습 모드 안내 (5회 소진 시) -->
      <div class="pvp-practice-banner" id="pvp-practice-banner" style="display:none">
        💡 <strong>연습 모드</strong> — 보상/승수는 적립되지 않아요. 누구든 자유롭게 도전 가능.
      </div>

      <div class="pvp-section-head">
        <h2>도전 상대</h2>
        <div class="pvp-section-actions">
          <button class="pvp-refresh-btn" type="button" id="pvp-search-trigger" style="display:none">
            🔍 대상 검색
          </button>
          <button class="pvp-refresh-btn" type="button" id="pvp-refresh-btn">🔄 새로 고침</button>
        </div>
      </div>

      <div class="pvp-opponents-box">
        <div class="pvp-opponents" id="pvp-opponents"></div>
      </div>

      <p class="pvp-note" id="pvp-matching-note"></p>
    </section>

    <!-- 대상 검색 다이얼로그 (연습 모드 시 진입) -->
    <dialog class="pvp-search-dialog" id="pvp-search-dialog" aria-labelledby="pvp-search-title">
      <div class="pvp-search-dialog-card">
        <header class="pvp-search-dialog-head">
          <strong id="pvp-search-title">대상 검색</strong>
          <button
            type="button"
            class="pvp-search-dialog-close"
            id="pvp-search-dialog-close"
            aria-label="닫기"
          >×</button>
        </header>
        <input
          type="text"
          class="tm-auth-search"
          id="pvp-search-input"
          placeholder="닉네임 또는 ID 검색"
          autocomplete="off"
        />
        <div class="pvp-search-list" id="pvp-search-list"></div>
        <p class="pvp-search-dialog-note">선택 시 즉시 도전 시작 — 연습 모드라 보상/승수 적립 X</p>
      </div>
    </dialog>

    <!-- view: battle -->
    <section class="pvp-view" data-view="battle" id="pvp-view-battle" style="display:none">
      <div class="pvp-arena">
        <div class="pvp-fighter" id="pvp-fighter-attacker">
          <img class="pvp-fighter-avatar" id="pvp-attacker-avatar" alt="" />
          <div class="pvp-fighter-info">
            <strong class="pvp-fighter-name" id="pvp-attacker-name">나</strong>
            <span class="pvp-fighter-power">⚔️ <span id="pvp-attacker-power">0</span></span>
          </div>
          <div class="pvp-hpbar">
            <div class="pvp-hpbar-fill" id="pvp-attacker-hp-fill" style="width:100%"></div>
            <span class="pvp-hpbar-text"><span id="pvp-attacker-hp">1000</span> / 1000</span>
          </div>
        </div>

        <div class="pvp-vs">VS</div>

        <div class="pvp-fighter pvp-fighter-defender" id="pvp-fighter-defender">
          <img class="pvp-fighter-avatar" id="pvp-defender-avatar" alt="" />
          <div class="pvp-fighter-info">
            <strong class="pvp-fighter-name" id="pvp-defender-name">상대</strong>
            <span class="pvp-fighter-power">⚔️ <span id="pvp-defender-power">0</span></span>
          </div>
          <div class="pvp-hpbar">
            <div class="pvp-hpbar-fill" id="pvp-defender-hp-fill" style="width:100%"></div>
            <span class="pvp-hpbar-text"><span id="pvp-defender-hp">1000</span> / 1000</span>
          </div>
        </div>
      </div>

      <div class="pvp-turn-info">
        Turn <strong id="pvp-turn">1</strong> / 5
      </div>

      <!-- 직전 턴 결과 -->
      <div class="pvp-last-turn" id="pvp-last-turn" style="display:none"></div>

      <div class="pvp-cards">
        <button class="pvp-card pvp-card-attack" type="button" data-card="attack">
          <span class="pvp-card-icon">⚔️</span>
          <strong class="pvp-card-name">공격</strong>
          <span class="pvp-card-desc">매턴 사용</span>
        </button>
        <button class="pvp-card pvp-card-enhance" type="button" data-card="enhance">
          <span class="pvp-card-icon">✨</span>
          <strong class="pvp-card-name">강화</strong>
          <span class="pvp-card-desc">크리 30% / 1턴 쿨</span>
        </button>
        <button class="pvp-card pvp-card-defend" type="button" data-card="defend">
          <span class="pvp-card-icon">🛡️</span>
          <strong class="pvp-card-name">방어</strong>
          <span class="pvp-card-desc">데미지 절반 / 1턴 쿨</span>
        </button>
      </div>

      <p class="pvp-mechanics-hint">
        💥 양쪽이 <strong>공격</strong> 동시 선택 시 <strong>격돌</strong> — 양쪽 HP 20% 깎임 (전투력 무관)
      </p>
    </section>

    <!-- view: result -->
    <section class="pvp-view" data-view="result" id="pvp-view-result" style="display:none">
      <div class="pvp-result-card">
        <div class="pvp-result-icon" id="pvp-result-icon">🎉</div>
        <h2 class="pvp-result-title" id="pvp-result-title">승리!</h2>
        <div class="pvp-result-reward">
          <span>💎</span>
          <strong id="pvp-result-reward">+200</strong>
          <span>크리스탈</span>
        </div>
        <div class="pvp-result-actions">
          <button class="pvp-result-btn pvp-result-again" type="button" id="pvp-result-again">다시 도전</button>
          <button class="pvp-result-btn pvp-result-close" type="button" id="pvp-result-close">매칭으로</button>
        </div>
      </div>
    </section>

    <RankingTable
      title="랭킹"
      refreshId="pvp-rank-refresh"
      bodyId="pvp-ranking-body"
      variant="table"
      colsClass="rank-pvp-cols"
    >
      <div slot="header" class="rank-header">
        <span class="rank-h-pos">#</span>
        <span class="rank-h-spacer" aria-hidden="true"></span>
        <span class="rank-h-name">닉네임</span>
        <button class="rank-h-sort active" type="button" data-sort="power">⚔️ 전투력</button>
        <button class="rank-h-sort" type="button" data-sort="pvp_wins">🏆 승수</button>
      </div>
    </RankingTable>

    <!-- 랭킹 row 클릭 시 띄우는 장비 보기 다이얼로그 (read-only) -->
    <dialog class="pvp-equipview-dialog" id="pvp-equipview-dialog" aria-labelledby="pvp-equipview-name">
      <div class="pvp-equipview-card">
        <header class="pvp-equipview-head">
          <strong id="pvp-equipview-name">-</strong>
          <button class="pvp-equipview-close" type="button" data-action="close-equipview" aria-label="닫기">×</button>
        </header>

        <!-- equipment 페이지의 .eq-stage 재사용 — read-only 모드 (.is-readonly) -->
        <div class="eq-stage pvp-equipview-stage is-readonly" id="pvp-equipview-stage">
          <div class="eq-avatar">
            <img class="eq-avatar-img" id="pvp-equipview-avatar-img" alt="" />
          </div>

          {SLOT_LAYOUT.map(({ slot, side, row }) => (
            <div
              class={`eq-slot eq-slot-${side} eq-slot-row-${row} eq-slot-tier-common`}
              data-pvp-view-slot={slot}
              aria-label={`${SLOT_LABEL[slot].name} (보기 전용)`}
            >
              <span class="eq-slot-badge" data-pvp-view-field="badge" hidden>+0</span>
              <img
                class="eq-slot-icon"
                src={SLOT_LABEL[slot].image}
                alt={SLOT_LABEL[slot].name}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}

          <div class="eq-totalpower">
            <span class="eq-totalpower-label">총 전투력:</span>
            <span class="eq-totalpower-value" id="pvp-equipview-total">+0</span>
          </div>
        </div>
      </div>
    </dialog>
  </div>
</AppLayout>

<script>
  import '@/scripts/pages/tile-match-auth';
  import { initPvP } from '@/scripts/pages/pvp';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPvP);
  } else {
    initPvP();
  }
</script>
