---
import AppLayout from '@/layouts/AppLayout.astro';
import { tabs, findActiveSubmenu } from '@/data/navigation';
import '@/styles/tools.css';

// 트랙 3 진행 중 — navigation 에서 tools 임시 제거. fallback 처리.
const tools = tabs.find((t) => t.id === 'tools');
const active = tools ? findActiveSubmenu(tools, Astro.url.pathname) : undefined;
const navItems =
  tools?.submenus?.map((s) => ({
    title: s.title,
    path: s.path,
    active: active?.id === s.id,
  })) ?? [];
---

<AppLayout
  title="건설 최적화 — PNX 연맹"
  description="건설 동선/순서를 최적화하는 도구"
  navHeader="게임도구"
  navItems={navItems}
>
  <div class="manage-page" id="page-build-optimizer">
    <div class="members-header">
      <h1>건설 최적화</h1>
    </div>

    <!-- 트랙 3 진행 중 — 운영 미공개 안내 (개발 완료 시 제거) -->
    <div
      style="margin: 12px 0; padding: 12px 16px; background: rgba(245, 158, 11, 0.12); border-left: 4px solid #f59e0b; border-radius: 6px; font-size: 13px; color: #92400e;"
    >
      🚧 <strong>현재 개발 중</strong>인 도구입니다. 정식 공개 전까지 결과가 정확하지 않을 수 있어요.
    </div>

    <div class="page-intro">
      <p>건축 시작 타이밍을 <strong>총리대신 / 펫 / 법령</strong> 조합 기준으로 추천합니다.</p>
      <ul>
        <li><strong>입력값</strong> 은 자동 저장 — 다음 방문 시 바로 이어서 계산</li>
        <li>지금 시작 vs 총리대신 기다리기 의 <strong>이득 시간</strong> 계산</li>
        <li><strong>손익분기 대기 시간</strong> 까지 기다려도 이득</li>
      </ul>
    </div>

    <!-- ===== 1. 공통 버프 ===== -->
    <section class="bo-section">
      <h2 class="bo-section-title">공통 버프</h2>

      <div class="bo-field">
        <label for="bo-base-speed" class="bo-label">기본 건설 속도 (%)</label>
        <input
          type="number"
          id="bo-base-speed"
          class="bo-input"
          inputmode="decimal"
          step="0.1"
          min="0"
          placeholder="예: 54.6"
        />
        <p class="bo-hint">연구/스탯 등 본인의 기본 건설 속도</p>
      </div>

      <div class="bo-field">
        <span class="bo-label">펫 버프 (회색늑대)</span>
        <div class="bo-pet-options" id="bo-pet-options">
          <label class="bo-pet-opt"><input type="radio" name="bo-pet" value="0" checked /><span>사용 X</span></label>
          <label class="bo-pet-opt"><input type="radio" name="bo-pet" value="5" /><span>5%</span></label>
          <label class="bo-pet-opt"><input type="radio" name="bo-pet" value="7" /><span>7%</span></label>
          <label class="bo-pet-opt"><input type="radio" name="bo-pet" value="9" /><span>9%</span></label>
          <label class="bo-pet-opt"><input type="radio" name="bo-pet" value="12" /><span>12%</span></label>
          <label class="bo-pet-opt"><input type="radio" name="bo-pet" value="15" /><span>15%</span></label>
        </div>
        <p class="bo-hint">스킬 사용 후 5분 이내 시작한 건축물에 적용</p>
      </div>

      <div class="bo-field">
        <label class="bo-label bo-toggle-row">
          <input type="checkbox" id="bo-law" />
          <span>법령 사용 — 시간 단축 20%</span>
        </label>
        <p class="bo-hint">사용 후 5분 이내 시작한 건축물에 적용 / 재사용 24시간</p>
      </div>
    </section>

    <!-- ===== 2. 총리대신 임명 시각 ===== -->
    <section class="bo-section">
      <h2 class="bo-section-title">총리대신 임명 시각</h2>
      <div class="bo-field">
        <label for="bo-pm-datetime" class="bo-label">예정 시각</label>
        <input
          type="text"
          id="bo-pm-datetime"
          class="bo-input"
          inputmode="text"
          autocomplete="off"
          placeholder="예: 2026-05-01 06:41:29"
        />
        <p class="bo-hint">
          게임 화면 표기 그대로 복붙 가능 — 날짜+시각 / 시각만 / 비워두면 즉시 임명 가능.
          지원 포맷: <code>2026-05-01 06:41:29</code>, <code>2026/05/01 06:41</code>, <code>06:41</code> (오늘, 지나간 시각이면 내일로)
        </p>
      </div>
    </section>

    <!-- ===== 3. 현재 건축 큐 ===== -->
    <section class="bo-section">
      <h2 class="bo-section-title">현재 건축 큐</h2>

      <div class="bo-field" data-queue="q1">
        <span class="bo-label">큐 1</span>
        <div class="bo-queue-options">
          <label class="bo-queue-opt"><input type="radio" name="bo-queue1-status" value="empty" checked /><span>비어있음</span></label>
          <label class="bo-queue-opt"><input type="radio" name="bo-queue1-status" value="building" /><span>건축 중</span></label>
        </div>
        <div class="bo-time-row" data-time-input="bo-queue1-time">
          <span class="bo-time-cell"><input type="number" min="0" data-unit="d" placeholder="0" /><em>일</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="23" data-unit="h" placeholder="0" /><em>시간</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="59" data-unit="m" placeholder="0" /><em>분</em></span>
        </div>
        <p class="bo-hint">건축 중 선택 시 남은 시간 입력</p>
      </div>

      <div class="bo-field" data-queue="q2">
        <span class="bo-label">큐 2</span>
        <div class="bo-queue-options">
          <label class="bo-queue-opt"><input type="radio" name="bo-queue2-status" value="empty" checked /><span>비어있음</span></label>
          <label class="bo-queue-opt"><input type="radio" name="bo-queue2-status" value="building" /><span>건축 중</span></label>
        </div>
        <div class="bo-time-row" data-time-input="bo-queue2-time">
          <span class="bo-time-cell"><input type="number" min="0" data-unit="d" placeholder="0" /><em>일</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="23" data-unit="h" placeholder="0" /><em>시간</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="59" data-unit="m" placeholder="0" /><em>분</em></span>
        </div>
      </div>
    </section>

    <!-- ===== 4. 다음 건축 후보 ===== -->
    <section class="bo-section">
      <h2 class="bo-section-title">다음 건축 후보 (최대 2개)</h2>

      <div class="bo-field">
        <span class="bo-label">후보 1 — 기본 건축 시간</span>
        <div class="bo-time-row" data-time-input="bo-cand1-time">
          <span class="bo-time-cell"><input type="number" min="0" data-unit="d" placeholder="0" /><em>일</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="23" data-unit="h" placeholder="0" /><em>시간</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="59" data-unit="m" placeholder="0" /><em>분</em></span>
        </div>
      </div>

      <div class="bo-field">
        <span class="bo-label">후보 2 — 기본 건축 시간</span>
        <div class="bo-time-row" data-time-input="bo-cand2-time">
          <span class="bo-time-cell"><input type="number" min="0" data-unit="d" placeholder="0" /><em>일</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="23" data-unit="h" placeholder="0" /><em>시간</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="59" data-unit="m" placeholder="0" /><em>분</em></span>
        </div>
        <p class="bo-hint">후보가 1개면 후보 2 는 비워둠</p>
      </div>
    </section>

    <!-- ===== 5. 보유 가속권 ===== -->
    <section class="bo-section">
      <h2 class="bo-section-title">보유 가속권 (선택)</h2>
      <div class="bo-field">
        <span class="bo-label">건축 가속권 합산</span>
        <div class="bo-time-row" data-time-input="bo-ticket-time">
          <span class="bo-time-cell"><input type="number" min="0" data-unit="d" placeholder="0" /><em>일</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="23" data-unit="h" placeholder="0" /><em>시간</em></span>
          <span class="bo-time-cell"><input type="number" min="0" max="59" data-unit="m" placeholder="0" /><em>분</em></span>
        </div>
        <p class="bo-hint">Phase 3 에서 가속권 사용 권장 분석에 활용 — 입력만 미리 받음</p>
      </div>
    </section>

    <button class="bo-calc-btn" id="bo-calc" type="button">계산하기</button>

    <!-- ===== 3. 결과 (PR 3 에서 다듬음. 지금은 단순 출력) ===== -->
    <section class="bo-result" id="bo-result" hidden>
      <h2 class="bo-section-title">추천 결과</h2>
      <div class="bo-result-card" id="bo-result-card"></div>
    </section>
  </div>
</AppLayout>

<script>
  import { initBuildOptimizer } from '@/scripts/pages/build-optimizer';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBuildOptimizer);
  } else {
    initBuildOptimizer();
  }
</script>
