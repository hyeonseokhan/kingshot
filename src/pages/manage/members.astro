---
import AppLayout from '@/layouts/AppLayout.astro';
import { tabs, findActiveSubmenu } from '@/data/navigation';
import '@/styles/manage.css';

const manage = tabs.find((t) => t.id === 'manage')!;
const active = findActiveSubmenu(manage, Astro.url.pathname);
const navItems = manage.submenus!.map((s) => ({
  title: s.title,
  path: s.path,
  active: active?.id === s.id,
}));
---

<AppLayout
  title="연맹원 관리 — PNX 연맹"
  description="PNX 연맹원 정보 관리"
  navHeader="연맹관리"
  navItems={navItems}
>
  <div class="manage-page" id="page-members">
    <div class="members-header">
      <h1>연맹원 관리</h1>
      <button class="btn btn-primary" id="btn-add-member" type="button">+ 연맹원 등록</button>
    </div>

    <div class="page-intro">
      <p><strong>PNX 연맹원 정보</strong>를 한눈에 관리하는 페이지입니다.</p>
      <ul>
        <li><strong>연맹원 등록</strong>: 킹샷 ID로 조회하면 닉네임/레벨/서버가 자동 입력됩니다</li>
        <li><strong>⋮ 관리 버튼</strong>: 등급, 쿠폰 자동 받기를 편집할 수 있어요</li>
        <li><strong>전체 갱신</strong>: 등록된 모든 연맹원의 프로필을 최신으로 업데이트합니다</li>
        <li><strong>쿠폰 자동 받기</strong>가 켜져 있으면 <strong>쿠폰 받기 페이지</strong>에 자동 포함됩니다</li>
      </ul>
      <p class="page-intro-hint">
        등급이 높고 레벨이 높은 순으로 정렬되며, 레벨 28~30 연맹원은 프로필에 특별한 효과가
        적용됩니다.
      </p>
    </div>

    <!-- 등록 모달 -->
    <div class="modal-overlay" id="modal-overlay">
      <div class="modal">
        <div class="modal-header">
          <h3>연맹원 등록</h3>
          <button class="modal-close" id="modal-close" type="button">&times;</button>
        </div>
        <div class="modal-body">
          <label for="input-kingshot-id">킹샷 ID</label>
          <div class="input-row">
            <input type="text" id="input-kingshot-id" placeholder="킹샷 아이디 입력" />
            <button class="btn btn-secondary" id="btn-search-id" type="button">조회</button>
          </div>
          <div id="search-result" class="player-card" style="display:none">
            <img id="res-photo" class="player-card-photo" src="" alt="" />
            <div class="player-card-info">
              <div class="player-card-name" id="res-nickname">-</div>
              <div class="player-card-detail">
                도시 센터 레벨: <strong id="res-level">-</strong>
              </div>
              <div class="player-card-detail">
                소속 왕국: <strong id="res-kingdom">-</strong>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" id="btn-modal-cancel" type="button">취소</button>
          <button class="btn btn-primary" id="btn-modal-save" type="button">저장</button>
        </div>
      </div>
    </div>

    <!-- 필터 & 카운트 -->
    <div class="members-toolbar">
      <div class="member-count" id="member-count"></div>
      <div class="members-toolbar-right">
        <div class="members-filter">
          <label for="filter-level">최소 레벨</label>
          <select id="filter-level">
            <option value="0">전체</option>
          </select>
        </div>
        <button class="btn btn-secondary btn-sm" id="btn-refresh-all" type="button"
          >전체 갱신</button
        >
      </div>
    </div>
    <div class="members-list" id="members-list">
      <div class="members-thead">
        <div></div>
        <div>닉네임</div>
        <div>등급</div>
        <div>레벨</div>
        <div>랭킹</div>
        <div>전투력</div>
        <div></div>
      </div>
      <div class="members-rows" id="members-rows"></div>
      <div class="empty-cell" id="members-status">로딩 중...</div>
    </div>

    <!-- 관리 다이얼로그 -->
    <div class="manage-dialog-overlay" id="manage-dialog-overlay">
      <div class="manage-dialog">
        <div class="md-profile">
          <div id="md-avatar"></div>
          <div class="md-profile-center">
            <div class="md-profile-name" id="md-name">-</div>
            <div class="md-profile-id" id="md-id">-</div>
            <div class="md-profile-meta" id="md-meta">-</div>
          </div>
          <button class="btn btn-secondary md-refresh-btn" id="md-refresh" title="정보 갱신" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 4v6h-6"></path>
              <path d="M1 20v-6h6"></path>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            </svg>
          </button>
        </div>
        <div class="manage-dialog-body">
          <div class="md-form-row">
            <span class="md-form-label">등급</span>
            <div class="md-form-value">
              <select id="md-rank" class="md-select">
                <option value="R5">R5</option>
                <option value="R4">R4</option>
                <option value="R3">R3</option>
                <option value="R2">R2</option>
                <option value="R1">R1</option>
              </select>
            </div>
          </div>
          <div class="md-form-row">
            <span class="md-form-label">쿠폰 자동</span>
            <div class="md-form-value">
              <label class="md-toggle">
                <input type="checkbox" id="md-auto-coupon" checked />
                <span class="md-toggle-slider"></span>
              </label>
            </div>
          </div>
        </div>
        <div class="manage-dialog-actions">
          <button class="md-action-save" id="md-save" type="button">저장</button>
          <button class="md-action-delete-btn" id="md-delete" type="button">삭제</button>
          <button class="md-action-close" id="md-close" type="button">닫기</button>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  import '@/scripts/pages/members';
</script>
