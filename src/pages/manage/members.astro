---
import AppLayout from '@/layouts/AppLayout.astro';
import { tabs, findActiveSubmenu } from '@/data/navigation';
import '@/styles/manage.css';

const manage = tabs.find((t) => t.id === 'manage')!;
const active = findActiveSubmenu(manage, Astro.url.pathname);
const navItems = manage.submenus!.map((s) => ({
  title: s.title,
  titleKey: s.titleKey,
  path: s.path,
  active: active?.id === s.id,
}));
---

<AppLayout
  title="연맹원 관리 — PNX 연맹"
  description="PNX 연맹원 정보 관리"
  navHeader={manage.title}
  navHeaderKey={manage.titleKey}
  navItems={navItems}
>
  <div class="manage-page" id="page-members">
    <div class="members-header">
      <h1 data-i18n="members.heading">연맹원 관리</h1>
      <button class="btn btn-primary" id="btn-add-member" type="button" data-i18n="members.addButton">+ 연맹원 등록</button>
    </div>

    <div class="page-intro">
      <p data-i18n-html="members.intro.paragraph"><strong>PNX 연맹원 정보</strong>를 한눈에 관리하는 페이지입니다.</p>
      <ul>
        <li data-i18n-html="members.intro.item1"><strong>연맹원 등록</strong>: 킹샷 ID로 조회하면 닉네임/레벨/서버가 자동 입력됩니다</li>
        <li data-i18n-html="members.intro.item2"><strong>⋮ 관리 버튼</strong>: 등급, 쿠폰 자동 받기를 편집할 수 있어요</li>
        <li data-i18n-html="members.intro.item3"><strong>전체 갱신</strong>: 등록된 모든 연맹원의 프로필을 최신으로 업데이트합니다</li>
        <li data-i18n-html="members.intro.item4"><strong>쿠폰 자동 받기</strong>가 켜져 있으면 <strong>쿠폰 받기 페이지</strong>에 자동 포함됩니다</li>
      </ul>
      <p class="page-intro-hint" data-i18n="members.intro.hint">
        등급이 높고 레벨이 높은 순으로 정렬되며, 레벨 28~30 연맹원은 프로필에 특별한 효과가
        적용됩니다.
      </p>
    </div>

    <!-- 등록 모달 -->
    <div class="modal-overlay" id="modal-overlay">
      <div class="modal">
        <div class="modal-header">
          <h3 data-i18n="members.modal.title">연맹원 등록</h3>
          <button class="modal-close" id="modal-close" type="button">&times;</button>
        </div>
        <div class="modal-body">
          <label for="input-kingshot-id" data-i18n="members.modal.idLabel">킹샷 ID</label>
          <div class="input-row">
            <input
              type="text"
              id="input-kingshot-id"
              placeholder="킹샷 아이디 입력"
              data-i18n-attr-placeholder="members.modal.idPlaceholder"
            />
            <button
              class="btn btn-secondary"
              id="btn-search-id"
              type="button"
              data-i18n="members.modal.searchButton"
            >조회</button>
          </div>
          <div id="search-result" class="player-card" style="display:none">
            <img id="res-photo" class="player-card-photo" src="" alt="" />
            <div class="player-card-info">
              <div class="player-card-name" id="res-nickname">-</div>
              <div class="player-card-detail">
                <span data-i18n="members.modal.cityLevelLabel">도시 센터 레벨:</span> <strong id="res-level">-</strong>
              </div>
              <div class="player-card-detail">
                <span data-i18n="members.modal.kingdomLabel">소속 왕국:</span> <strong id="res-kingdom">-</strong>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" id="btn-modal-cancel" type="button" data-i18n="common.cancel">취소</button>
          <button class="btn btn-primary" id="btn-modal-save" type="button" data-i18n="common.save">저장</button>
        </div>
      </div>
    </div>

    <!-- 필터 & 카운트 -->
    <div class="members-toolbar">
      <div class="member-count" id="member-count"></div>
      <div class="members-toolbar-right">
        <div class="members-filter">
          <label for="filter-level" data-i18n="members.filter.minLevelLabel">최소 레벨</label>
          <select id="filter-level">
            <option value="0" data-i18n="members.filter.all">전체</option>
          </select>
        </div>
        <button class="btn btn-secondary btn-sm" id="btn-refresh-all" type="button"
          data-i18n="members.refreshAllButton">전체 갱신</button
        >
      </div>
    </div>
    <div class="members-list" id="members-list">
      <div class="members-thead">
        <div></div>
        <div data-i18n="members.thead.nickname">닉네임</div>
        <div data-i18n="members.thead.rank">등급</div>
        <div data-i18n="members.thead.level">레벨</div>
        <div data-i18n="members.thead.position">랭킹</div>
        <div data-i18n="members.thead.power">전투력</div>
        <div></div>
      </div>
      <div class="members-rows" id="members-rows"></div>
      <div class="empty-cell" id="members-status" data-i18n="common.loading">로딩 중...</div>
    </div>

    <!-- 관리 다이얼로그 -->
    <div class="manage-dialog-overlay" id="manage-dialog-overlay">
      <div class="manage-dialog">
        <div class="md-profile">
          <div id="md-avatar"></div>
          <div class="md-profile-center">
            <div class="md-profile-name" id="md-name">-</div>
            <div class="md-profile-id" id="md-id">-</div>
            <div class="md-profile-meta" id="md-meta">-</div>
          </div>
          <button
            class="btn btn-secondary md-refresh-btn"
            id="md-refresh"
            title="정보 갱신"
            data-i18n-attr-title="members.dialog.refreshTitle"
            type="button"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 4v6h-6"></path>
              <path d="M1 20v-6h6"></path>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            </svg>
          </button>
        </div>
        <div class="manage-dialog-body">
          <div class="md-form-row">
            <span class="md-form-label" data-i18n="members.dialog.rank">등급</span>
            <div class="md-form-value">
              <select id="md-rank" class="md-select">
                <option value="R5">R5</option>
                <option value="R4">R4</option>
                <option value="R3">R3</option>
                <option value="R2">R2</option>
                <option value="R1">R1</option>
              </select>
            </div>
          </div>
          <div class="md-form-row">
            <span class="md-form-label" data-i18n="members.dialog.autoCoupon">쿠폰 자동 수령</span>
            <div class="md-form-value">
              <label class="md-toggle">
                <input type="checkbox" id="md-auto-coupon" checked />
                <span class="md-toggle-slider"></span>
              </label>
            </div>
          </div>
          <!-- 관리자 전용 섹션 (is_admin = true 일 때만 노출 — JS 가 제어) -->
          <div class="md-admin-section" id="md-admin-section" hidden>
            <button class="md-admin-grant-btn" id="md-admin-grant" type="button" data-i18n="members.dialog.adminGrantButton">💎 크리스탈 지급</button>
          </div>
        </div>
        <div class="manage-dialog-actions">
          <button class="md-action-save" id="md-save" type="button" data-i18n="members.dialog.save">저장</button>
          <button class="md-action-delete-btn" id="md-delete" type="button" data-i18n="members.dialog.delete">삭제</button>
          <button class="md-action-close" id="md-close" type="button" data-i18n="members.dialog.close">닫기</button>
        </div>
      </div>
    </div>

    <!-- 관리자 크리스탈 지급 다이얼로그 (native <dialog>, top layer) -->
    <dialog class="grant-dialog" id="grant-dialog">
      <form method="dialog" class="grant-form">
        <h3 class="grant-title">
          <span data-i18n="members.grantDialog.title">크리스탈 지급</span>
          <span class="grant-target" id="grant-target">-</span>
        </h3>
        <div class="grant-field">
          <label for="grant-amount" data-i18n="members.grantDialog.amountLabel">지급 수량 (1~300,000)</label>
          <input
            type="number"
            id="grant-amount"
            min="1"
            max="300000"
            step="1"
            inputmode="numeric"
            pattern="[0-9]+"
            required
            placeholder="예: 5000"
            data-i18n-attr-placeholder="members.grantDialog.amountPlaceholder"
          />
        </div>
        <div class="grant-field">
          <label for="grant-source" data-i18n="members.grantDialog.sourceLabel">사유 분류</label>
          <select id="grant-source" required>
            <option value="event" data-i18n="members.grantDialog.sourceEvent">이벤트 보상</option>
            <option value="activity" data-i18n="members.grantDialog.sourceActivity">활동 보상</option>
            <option value="compensation" data-i18n="members.grantDialog.sourceCompensation">보전</option>
            <option value="misc" data-i18n="members.grantDialog.sourceMisc">기타</option>
          </select>
        </div>
        <div class="grant-field">
          <label for="grant-memo" data-i18n="members.grantDialog.memoLabel">메모 (선택, 최대 200자)</label>
          <textarea
            id="grant-memo"
            maxlength="200"
            rows="3"
            placeholder="지급 사유를 자유롭게 적어두세요"
            data-i18n-attr-placeholder="members.grantDialog.memoPlaceholder"
          ></textarea>
        </div>
        <div class="grant-status" id="grant-status" role="status" aria-live="polite"></div>
        <div class="grant-actions">
          <button type="button" id="grant-cancel" class="grant-btn-cancel" data-i18n="common.cancel">취소</button>
          <button type="button" id="grant-submit" class="grant-btn-submit" data-i18n="members.grantDialog.submit">지급</button>
        </div>
      </form>
    </dialog>
  </div>
</AppLayout>

<script>
  import '@/scripts/pages/members';
</script>
