---
// 주간 랭킹 안내 컴포넌트 (Track 7 — 컴팩트 라인 레이아웃)
//   - 미니게임 페이지 상단의 게임 설명 바로 아래 배치
//   - 가장 최근 주차의 1·2·3등 한 줄씩 (메달 + 닉네임 + 보상)
//   - 4~10등 안내는 우하단 작은 글씨
//   - 데이터 0건이면 "아직 집계된 결과가 없습니다"
//
// 스타일은 src/styles/minigame.css 의 .wrp-* (Astro scope 가 JS 주입 row 에 안 닿음 → 글로벌 통합)
// 동작 로직: src/scripts/components/weekly-rankings-panel.ts
interface Props {
  game: 'tile_match' | 'pvp';
}
const { game } = Astro.props;
---

<section class="wrp" data-game={game} aria-busy="true">
  <div class="wrp-card">
    <div class="wrp-header">
      <span class="wrp-icon" aria-hidden="true">🏆</span>
      <h3 class="wrp-title">
        <span class="wrp-week" data-field="week-label">—</span>
        <span data-i18n="weeklyRankings.titleSuffix">순위결과</span>
      </h3>
    </div>
    <ol class="wrp-podium" data-field="podium" hidden>
      <!-- 동적 — 1·2·3등 row 삽입 (li.wrp-row) -->
    </ol>
    <p class="wrp-note" data-field="bottom-note" hidden data-i18n="weeklyRankings.belowNote">
      4~10등은 각 2,000 크리스탈 지급
    </p>
    <p class="wrp-empty" data-field="empty" hidden data-i18n="weeklyRankings.empty">
      아직 집계된 결과가 없습니다
    </p>
  </div>
</section>

<script>
  import '@/scripts/components/weekly-rankings-panel';
</script>
