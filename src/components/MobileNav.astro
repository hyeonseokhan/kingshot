---
import { tabs, findActiveTab, findActiveSubmenu } from '@/data/navigation';
import { getGuidesByCategory, entryToSlug, type GuideCategory } from '@/lib/guides';

const pathname = Astro.url.pathname;
const activeTab = findActiveTab(pathname);

// 가이드 카테고리별 항목 — 빌드 시 한 번 로드.
const beginnerGuides = await getGuidesByCategory('beginner');
const eventsGuides = await getGuidesByCategory('events');

type Child = {
  title: string;
  /** i18n 키 (앱 탭 서브메뉴만). 가이드 항목은 undefined → 한글 유지 (마크다운 데이터). */
  titleKey?: string;
  path: string;
  active: boolean;
  /** 앱 탭의 서브메뉴 id (있는 경우만) */
  submenu?: string;
  /** 가이드 탭의 슬러그 (있는 경우만) */
  section?: string;
};

function buildChildren(tabId: string): Child[] {
  const tab = tabs.find((t) => t.id === tabId)!;
  if (tab.submenus) {
    const activeSub = findActiveSubmenu(tab, pathname);
    return tab.submenus.map((s) => ({
      title: s.title,
      titleKey: s.titleKey,
      path: s.path,
      active: activeSub?.id === s.id,
      submenu: s.id,
    }));
  }
  // 가이드 탭(beginner/events) — 마크다운 컬렉션의 order 순 항목을 children 으로
  const guides = tabId === 'beginner' ? beginnerGuides : eventsGuides;
  return guides.map((g, idx) => {
    const slug = entryToSlug(g);
    const path = `/${tabId as GuideCategory}/${slug}/`;
    // 인덱스 진입(/, /events/) 시 첫 항목을 active 로 간주
    let active = pathname === path;
    if (!active && idx === 0) {
      if (tabId === 'beginner' && pathname === '/') active = true;
      if (tabId === 'events' && pathname === '/events/') active = true;
    }
    return { title: g.data.title, path, active, section: slug };
  });
}

const tabsWithChildren = tabs.map((t) => ({ ...t, children: buildChildren(t.id) }));
---

<div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>
<aside class="mobile-nav-panel" id="mobile-nav-panel">
  <div class="mobile-nav-close">
    <span class="mobile-nav-close-label" data-i18n="header.menuOpen">메뉴</span>
    <button
      id="mobile-nav-close"
      type="button"
      aria-label="메뉴 닫기"
      data-i18n-attr-aria-label="header.menuClose">&times;</button>
  </div>
  {
    tabsWithChildren.map((tab) => {
      const isCurrentTab = activeTab?.id === tab.id;
      return (
        <>
          <button
            class:list={['mobile-nav-tab', { expanded: isCurrentTab }]}
            data-tab={tab.id}
            type="button"
          >
            <span data-i18n={tab.titleKey}>{tab.title}</span>
            <span class="mobile-nav-toggle">▸</span>
          </button>
          <div
            class:list={['mobile-nav-children', { open: isCurrentTab }]}
            data-parent={tab.id}
          >
            {tab.children.map((c) => (
              <a
                href={c.path}
                class:list={['mobile-nav-section', { active: c.active }]}
                data-tab={tab.id}
                data-submenu={c.submenu}
                data-section={c.section}
                data-i18n={c.titleKey}
              >
                {c.title}
              </a>
            ))}
          </div>
        </>
      );
    })
  }

  <!-- 언어 선택 — 헤더의 LangSwitcher 가 모바일에선 숨겨지고 여기로 이동.
       폰 설정 화면 패턴: row [🌐 Language ............ 한국어 ▾]
       native <select> 라 OS 별 picker (iOS wheel / Android 모달) 가 자동 노출됨.
       동기화: lang-switcher.ts 의 [data-set-lang-select] 핸들러. -->
  <div class="mobile-nav-langs">
    <label class="mobile-nav-lang-row">
      <span class="mobile-nav-lang-icon" aria-hidden="true">🌐</span>
      <span class="mobile-nav-lang-label" data-i18n="langSwitcher.label">언어</span>
      <span class="mobile-nav-lang-select-wrap">
        <select class="mobile-nav-lang-select" data-set-lang-select>
          <option value="ko">한국어</option>
          <option value="en">English</option>
        </select>
        <span class="mobile-nav-lang-caret" aria-hidden="true">▾</span>
      </span>
    </label>
  </div>
</aside>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-nav-overlay');
  const panel = document.getElementById('mobile-nav-panel');
  const closeBtn = document.getElementById('mobile-nav-close');

  function openMenu() {
    overlay?.classList.add('open');
    panel?.classList.add('open');
  }
  function closeMenu() {
    overlay?.classList.remove('open');
    panel?.classList.remove('open');
  }

  btn?.addEventListener('click', openMenu);
  overlay?.addEventListener('click', closeMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // 탭 버튼 클릭 → children 토글 (한 번에 한 탭만 펼침). 페이지 이동 안 함.
  panel?.querySelectorAll<HTMLButtonElement>('.mobile-nav-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const tabId = tab.dataset.tab;
      if (!tabId) return;
      const children = panel.querySelector<HTMLDivElement>(
        `.mobile-nav-children[data-parent="${tabId}"]`,
      );
      if (!children) return;
      const isOpen = children.classList.contains('open');

      panel
        .querySelectorAll('.mobile-nav-children')
        .forEach((c) => c.classList.remove('open'));
      panel
        .querySelectorAll('.mobile-nav-tab')
        .forEach((t) => t.classList.remove('expanded'));

      if (!isOpen) {
        children.classList.add('open');
        tab.classList.add('expanded');
      }
    });
  });
</script>

<style>
  .mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.4);
  }
  .mobile-nav-overlay.open {
    display: block;
  }

  .mobile-nav-panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 300px;
    background: var(--bg-header);
    color: #fff;
    z-index: 201;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    overflow-y: auto;
    padding: 0;
  }
  .mobile-nav-panel.open {
    transform: translateX(0);
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.3);
  }

  .mobile-nav-close {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  /* "메뉴" 라벨 — pseudo content 는 i18n 처리 못 해서 실제 element 로 분리 */
  .mobile-nav-close-label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.5);
  }
  .mobile-nav-close button {
    background: none;
    border: none;
    font-size: 22px;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.15s;
  }
  .mobile-nav-close button:hover {
    color: #fff;
  }

  .mobile-nav-tab {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 20px;
    font-size: 15px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    cursor: pointer;
    border: none;
    border-left: 3px solid transparent;
    background: none;
    transition: all 0.15s;
    font-family: var(--font);
    text-align: left;
  }
  .mobile-nav-tab:hover {
    background: rgba(255, 255, 255, 0.06);
  }
  .mobile-nav-tab.expanded {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    border-left-color: var(--accent-light);
  }

  .mobile-nav-toggle {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    transition: transform 0.2s;
  }
  .mobile-nav-tab.expanded .mobile-nav-toggle {
    transform: rotate(90deg);
    color: rgba(255, 255, 255, 0.7);
  }

  .mobile-nav-children {
    display: none;
  }
  .mobile-nav-children.open {
    display: block;
  }

  .mobile-nav-section {
    display: block;
    padding: 10px 20px 10px 36px;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all 0.12s;
    text-decoration: none;
  }
  .mobile-nav-section:hover {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }
  .mobile-nav-section.active {
    color: var(--accent-light);
    font-weight: 600;
  }

  /* === 언어 선택 (메뉴 하단) — 폰 설정 row 패턴 === */
  .mobile-nav-langs {
    margin-top: 12px;
    padding: 12px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .mobile-nav-langs::before {
    content: 'SETTING';
    display: block;
    padding: 0 20px 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
  }
  .mobile-nav-lang-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
  }
  .mobile-nav-lang-icon {
    font-size: 15px;
    line-height: 1;
  }
  .mobile-nav-lang-label {
    flex: 1;
  }

  /* select wrapper — caret 을 직접 그려서 OS 기본 화살표 대신 일관된 외관 */
  .mobile-nav-lang-select-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .mobile-nav-lang-select {
    appearance: none;
    -webkit-appearance: none;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: #fff;
    font-family: var(--font);
    font-size: 13.5px;
    font-weight: 500;
    padding: 6px 26px 6px 12px;
    border-radius: 6px;
    cursor: pointer;
    line-height: 1.4;
    transition: background 0.15s;
  }
  .mobile-nav-lang-select:hover,
  .mobile-nav-lang-select:focus {
    background: rgba(255, 255, 255, 0.12);
    outline: none;
  }
  .mobile-nav-lang-select option {
    background: #2a2f36;
    color: #fff;
  }
  .mobile-nav-lang-caret {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 11px;
    color: rgba(255, 255, 255, 0.6);
    pointer-events: none;
  }
</style>
