---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings?: MarkdownHeading[];
  /** 가이드 페이지의 언어 페어 — 두 인스턴스 (ko/en) 렌더 시 swap 마커. */
  lang?: 'ko' | 'en';
}

const { headings = [], lang } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---

<aside class="right-toc" data-toc-root data-toc-lang={lang}>
  <div class="right-toc-header">ON THIS PAGE</div>
  <div class="right-toc-items">
    {
      items.map((h) => (
        <a
          href={`#${h.slug}`}
          class:list={['right-toc-item', `level-${h.depth}`]}
          data-slug={h.slug}
        >
          {h.text.replace(/^#\s*/, '')}
        </a>
      ))
    }
  </div>
</aside>

<script>
  // 스크롤 스파이 — 본문 스크롤 위치에 따라 활성 TOC 항목 토글.
  function setup() {
    const scroller = document.querySelector<HTMLElement>('.center-content');
    const tocItems = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('.right-toc-item[data-slug]'),
    );
    if (!scroller || tocItems.length === 0) return;

    const targets = tocItems
      .map((item) => {
        const slug = item.dataset.slug;
        const el = slug ? document.getElementById(slug) : null;
        return el ? { el, item } : null;
      })
      .filter((x): x is { el: HTMLElement; item: HTMLAnchorElement } => x !== null);
    if (targets.length === 0) return;

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const top = scroller!.scrollTop + 80;
        let active: (typeof targets)[number] | null = null;
        for (const t of targets) {
          if (t.el.offsetTop <= top) active = t;
        }
        for (const t of targets) t.item.classList.remove('active');
        if (active) active.item.classList.add('active');
        ticking = false;
      });
    }

    scroller.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // TOC 항목 클릭 → 부드럽게 스크롤
    for (const item of tocItems) {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = item.dataset.slug;
        const el = slug ? document.getElementById(slug) : null;
        if (!el) return;
        scroller!.scrollTo({ top: el.offsetTop - 60, behavior: 'smooth' });
        history.replaceState(null, '', `#${slug}`);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>

<style>
  .right-toc {
    width: var(--right-w);
    flex-shrink: 0;
    background: var(--bg);
    border-left: 1px solid var(--border2);
    overflow-y: auto;
    padding: 20px 0;
  }
  .right-toc-header {
    padding: 0 16px 10px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text3);
  }
  .right-toc-item {
    display: block;
    padding: 5px 16px;
    font-size: 12.5px;
    color: var(--text3);
    cursor: pointer;
    border-left: 2px solid transparent;
    transition: all 0.12s;
    line-height: 1.4;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
    text-decoration: none;
  }
  .right-toc-item:hover {
    color: var(--text);
    text-decoration: none;
  }
  .right-toc-item.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  .right-toc-item.level-3 {
    padding-left: 28px;
    font-size: 12px;
  }
  .right-toc-item.level-4 {
    padding-left: 40px;
    font-size: 11.5px;
  }

  @media (max-width: 1024px) {
    .right-toc {
      display: none;
    }
  }

  /* 가이드 페이지 ko/en pair — 현재 <html lang> 따라 한쪽만 표시 */
  :global(html[lang='ko'] .right-toc[data-toc-lang='en']),
  :global(html[lang='en'] .right-toc[data-toc-lang='ko']) {
    display: none;
  }
</style>
