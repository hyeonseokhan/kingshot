---
// Phase 3 에서 가이드 본문의 heading 을 자동 추출해 채울 예정.
// Phase 2 단계에서는 빈 셸만 노출.
---

<aside class="right-toc">
  <div class="right-toc-header">ON THIS PAGE</div>
  <div class="right-toc-items" id="right-toc-items"></div>
</aside>

<style>
  .right-toc {
    width: var(--right-w);
    flex-shrink: 0;
    background: var(--bg);
    border-left: 1px solid var(--border2);
    overflow-y: auto;
    padding: 20px 0;
  }
  .right-toc-header {
    padding: 0 16px 10px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text3);
  }

  @media (max-width: 1024px) {
    .right-toc {
      display: none;
    }
  }
</style>
