---
import { tabs, findActiveTab } from '@/data/navigation';
import LoginedUserInfo from '@/components/LoginedUserInfo.astro';
import LangSwitcher from '@/components/LangSwitcher.astro';

const pathname = Astro.url.pathname;
const activeTab = findActiveTab(pathname);
---

<header class="app-header">
  <div class="header-left">
    <a href="/" class="logo" aria-label="PNX">
      <img src="/logo.png" alt="PNX" width="32" height="32" decoding="async" />
    </a>
    <span class="header-title" data-i18n="header.title">연맹 가이드</span>
  </div>
  <nav class="tab-bar">
    {
      tabs.map((tab) => (
        <a
          href={tab.path}
          class:list={['tab', { active: activeTab?.id === tab.id }]}
          data-tab={tab.id}
          data-i18n={tab.titleKey}
        >
          {tab.title}
        </a>
      ))
    }
  </nav>
  <LoginedUserInfo />
  <button
    class="mobile-menu-btn"
    id="mobile-menu-btn"
    aria-label="메뉴"
    data-i18n-attr-aria-label="header.menuOpen"
    type="button">&#9776;</button
  >
  <LangSwitcher />
</header>

<style>
  .app-header {
    background: var(--bg-header);
    color: #fff;
    height: var(--header-h);
    display: flex;
    align-items: center;
    padding: 0 20px;
    gap: 16px;
    flex-shrink: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }


  /* PNX 피닉스 로고 — 자체 round corner + 그림자 포함된 아이콘 PNG. 추가 박스 없이 단독 표시. */
  .logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    line-height: 0;
  }
  .logo img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .header-title {
    font-size: 15px;
    font-weight: 600;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .tab-bar {
    display: flex;
    gap: 2px;
    margin-left: 32px;
    height: 100%;
    align-items: center;
  }

  .tab {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.55);
    padding: 6px 16px;
    cursor: pointer;
    font-size: 13.5px;
    font-weight: 500;
    font-family: var(--font);
    border-bottom: none;
    border-radius: 6px;
    transition: all 0.15s;
    text-decoration: none;
  }
  .tab:hover {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }
  .tab.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .app-header {
      padding: 0 12px;
      gap: 10px;
    }
    .header-title {
      font-size: 13px;
    }
    .tab-bar {
      display: none;
    }
    .mobile-menu-btn {
      display: block;
    }
  }
</style>
