---
import { tabs, findActiveTab } from '@/data/navigation';

const pathname = Astro.url.pathname;
const activeTab = findActiveTab(pathname);
---

<header class="app-header">
  <div class="header-left">
    <div class="logo">PNX</div>
    <span class="header-title">연맹 가이드</span>
  </div>
  <nav class="tab-bar">
    {
      tabs.map((tab) => (
        <a
          href={tab.path}
          class:list={['tab', { active: activeTab?.id === tab.id }]}
          data-tab={tab.id}
        >
          {tab.title}
        </a>
      ))
    }
  </nav>
  <div
    id="header-crystal-badge"
    class="header-crystal-badge"
    style="display: none;"
    aria-label="크리스탈 잔액"
  >
    <span class="header-crystal-icon">✨</span>
    <span id="header-crystal-value" class="header-crystal-value">0</span>
  </div>
  <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="메뉴" type="button"
    >&#9776;</button
  >
</header>

<script>
  import '@/scripts/header-crystal-badge';
</script>

<style>
  .app-header {
    background: var(--bg-header);
    color: #fff;
    height: var(--header-h);
    display: flex;
    align-items: center;
    padding: 0 20px;
    gap: 16px;
    flex-shrink: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo {
    padding: 0 8px;
    height: 30px;
    background: linear-gradient(135deg, #f59e0b, #ef4444);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 11px;
    line-height: 30px;
    color: #fff;
    letter-spacing: 0.02em;
  }

  .header-title {
    font-size: 15px;
    font-weight: 600;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .tab-bar {
    display: flex;
    gap: 2px;
    margin-left: 32px;
    height: 100%;
    align-items: center;
  }

  .tab {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.55);
    padding: 6px 16px;
    cursor: pointer;
    font-size: 13.5px;
    font-weight: 500;
    font-family: var(--font);
    border-bottom: none;
    border-radius: 6px;
    transition: all 0.15s;
    text-decoration: none;
  }
  .tab:hover {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }
  .tab.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
    margin-left: auto;
  }

  /* 크리스탈 잔액 배지 — sessionStorage 인증된 사용자에게만 표시 */
  .header-crystal-badge {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 11px;
    background: rgba(99, 102, 241, 0.18);
    border: 1px solid rgba(165, 180, 252, 0.45);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    line-height: 1.4;
    white-space: nowrap;
  }
  .header-crystal-icon {
    font-size: 14px;
    line-height: 1;
  }
  .header-crystal-value {
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 768px) {
    .app-header {
      padding: 0 12px;
      gap: 10px;
    }
    .header-title {
      font-size: 13px;
    }
    .tab-bar {
      display: none;
    }
    .mobile-menu-btn {
      display: block;
      margin-left: 0;
    }
    .header-crystal-badge {
      font-size: 12px;
      padding: 3px 9px;
    }
  }
</style>
