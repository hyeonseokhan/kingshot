---
type Item = {
  title: string;
  /** i18n 키 (있으면 클라이언트 lang swap 시 자동 갱신). */
  titleKey?: string;
  /** 가이드 페이지용 — pair 의 영문 title 직접 전달 (마크다운 frontmatter). */
  titleEn?: string;
  path: string;
  active?: boolean;
};

interface Props {
  header: string;
  /** i18n 키 (있으면 클라이언트 lang swap 시 자동 갱신). */
  headerKey?: string;
  items: Item[];
}

const { header, headerKey, items } = Astro.props;
---

<nav class="left-nav">
  <div class="left-nav-header" data-i18n={headerKey}>{header}</div>
  <div class="left-nav-items">
    {
      items.map((item) =>
        item.titleEn ? (
          // 가이드 페이지 — ko/en title 둘 다 embed, html[lang] selector 로 swap
          <a
            href={item.path}
            class:list={['left-nav-item', { active: item.active }]}
          >
            <span class="step-label">
              <span class="step-label-ko">{item.title}</span>
              <span class="step-label-en">{item.titleEn}</span>
            </span>
          </a>
        ) : (
          <a
            href={item.path}
            class:list={['left-nav-item', { active: item.active }]}
          >
            <span class="step-label" data-i18n={item.titleKey}>{item.title}</span>
          </a>
        ),
      )
    }
  </div>
</nav>

<style>
  .left-nav {
    width: var(--left-w);
    flex-shrink: 0;
    background: var(--bg);
    border-right: 1px solid var(--border2);
    overflow-y: auto;
    padding: 16px 0;
  }

  .left-nav-header {
    padding: 0 16px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text3);
  }

  .left-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    cursor: pointer;
    font-size: 13.5px;
    color: var(--text2);
    border-left: 2px solid transparent;
    transition: all 0.12s;
    text-decoration: none;
  }
  .left-nav-item:hover {
    background: var(--bg2);
    color: var(--text);
    text-decoration: none;
  }
  .left-nav-item.active {
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-bg);
    border-left-color: var(--accent);
  }
  .step-label {
    line-height: 1.3;
  }

  /* 가이드 페이지 ko/en pair — 현재 <html lang> 따라 한쪽만 표시.
     :global() 안에 전체 selector 박아야 child 의 scoping attr 영향 받지 않음. */
  :global(html[lang='ko'] .step-label-en),
  :global(html[lang='en'] .step-label-ko) {
    display: none;
  }

  @media (max-width: 768px) {
    .left-nav {
      display: none;
    }
  }
</style>
