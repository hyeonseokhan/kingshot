---
// 미니게임 런치 카드 — 타일매치/운명파트너 공통.
// 압축 레이아웃: padding/gap 축소 + 헤드를 한 줄에 배치(라벨 · 값).
//
// 사용:
//   <MinigameLaunchCard
//     label="다음 스테이지"
//     metaPrefix="Stage"
//     ctaLabel="게임 시작"
//     ctaId="tm-launch-btn"
//   >
//     <span slot="value" id="tm-launch-stage">1</span>
//   </MinigameLaunchCard>
//
//   stepper 같은 보조 컨트롤은 <slot name="controls"> 로 주입.

interface Props {
  label: string;
  /** i18n 키 (있으면 클라이언트 lang swap 시 자동 갱신). */
  labelKey?: string;
  metaPrefix?: string;
  metaPrefixKey?: string;
  metaSuffix?: string;
  metaSuffixKey?: string;
  ctaLabel: string;
  ctaLabelKey?: string;
  ctaId: string;
}

const { label, labelKey, metaPrefix, metaPrefixKey, metaSuffix, metaSuffixKey, ctaLabel, ctaLabelKey, ctaId } = Astro.props;
---

<div class="mlc">
  <div class="mlc-head">
    <span class="mlc-label" data-i18n={labelKey}>{label}</span>
    <span class="mlc-meta">
      {metaPrefix && <span class="mlc-meta-prefix" data-i18n={metaPrefixKey}>{metaPrefix}</span>}
      <span class="mlc-meta-value"><slot name="value" /></span>
      {metaSuffix && <span class="mlc-meta-suffix" data-i18n={metaSuffixKey}>{metaSuffix}</span>}
    </span>
  </div>
  <slot name="controls" />
  <button class="mlc-cta" id={ctaId} type="button" data-i18n={ctaLabelKey}>{ctaLabel}</button>
</div>

<style>
  .mlc {
    background: linear-gradient(180deg, #ffffff, #f7f9fc);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    margin: 12px auto;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    position: relative;
  }

  .mlc-head {
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    line-height: 1.3;
  }

  .mlc-label {
    font-size: 13px;
    color: var(--text2);
    font-weight: 500;
  }

  .mlc-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    font-size: 13px;
  }
  .mlc-meta-prefix,
  .mlc-meta-suffix {
    color: var(--text3);
  }
  .mlc-meta-value {
    color: var(--text);
    font-weight: 700;
    font-size: 16px;
  }

  .mlc-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: linear-gradient(180deg, #6cc26a, #4ca84a);
    color: #ffffff;
    border: 0;
    border-radius: 12px;
    padding: 10px 28px;
    font-size: 15px;
    font-weight: 700;
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.16), inset 0 -2px 0 rgba(0, 0, 0, 0.13);
    cursor: pointer;
    transition: transform 0.12s ease, filter 0.12s ease;
  }
  .mlc-cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
  .mlc-cta:active {
    transform: translateY(1px);
  }

  @media (max-width: 768px) {
    .mlc {
      padding: 12px 14px;
      margin: 10px 0;
      gap: 8px;
    }
    .mlc-cta {
      padding: 9px 24px;
      font-size: 14px;
    }
  }
</style>
