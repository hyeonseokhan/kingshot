---
// 미니게임 본인 인증 다이얼로그 — tile-match 와 partner-draw 가 공유.
// 동작 로직은 src/scripts/pages/tile-match-auth.ts.
---

<div class="tm-auth-overlay" id="tm-auth-overlay" style="display:none">
  <div class="tm-auth-dialog">
    <div class="tm-auth-bar">
      <button
        class="tm-dlg-close-btn tm-auth-back-btn"
        id="tm-auth-back"
        type="button"
        aria-label="뒤로"
        style="display:none"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <polyline points="15 6 9 12 15 18"></polyline>
        </svg>
      </button>
      <div class="tm-auth-title">계정 인증</div>
      <button
        class="tm-dlg-close-btn"
        id="tm-auth-close"
        type="button"
        aria-label="닫기"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="6" y1="18" x2="18" y2="6"></line>
        </svg>
      </button>
    </div>
    <div class="tm-auth-body">
      <div class="tm-auth-step" id="tm-auth-step-select">
        <p class="tm-auth-desc">
          미니게임은 <strong>연맹원 본인 인증</strong> 후 이용할 수 있습니다.
        </p>
        <input
          type="text"
          class="tm-auth-search"
          id="tm-auth-search"
          placeholder="닉네임 또는 ID 검색"
          autocomplete="off"
        />
        <div class="tm-auth-list" id="tm-auth-list"></div>
      </div>
      <div class="tm-auth-step" id="tm-auth-step-pin" style="display:none">
        <div class="tm-auth-selected" id="tm-auth-selected"></div>
        <p class="tm-auth-pin-prompt" id="tm-auth-pin-prompt">PIN 4자리를 입력하세요</p>
        <div class="tm-pin-wrap" id="tm-pin-wrap">
          <input
            class="tm-pin-input"
            id="tm-pin-input"
            type="text"
            inputmode="numeric"
            pattern="[0-9]*"
            maxlength="4"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            spellcheck="false"
            aria-label="PIN 4자리 입력"
          />
          <div class="tm-pin-boxes" id="tm-pin-boxes" aria-hidden="true">
            <div class="tm-pin-box"></div>
            <div class="tm-pin-box"></div>
            <div class="tm-pin-box"></div>
            <div class="tm-pin-box"></div>
          </div>
        </div>
        <div class="tm-auth-msg" id="tm-auth-msg"></div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /*
   * AuthDialog 전용 스타일.
   * is:global: 다이얼로그 내부 멤버 리스트(tile-match-auth.ts 가 동적 생성하는 .tm-auth-item 등)에도
   * 스타일이 적용되도록 컴포넌트 스코핑을 끔.
   */
  .tm-auth-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 1100;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tm-auth-dialog {
    background: #ffffff;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    width: 100%;
    height: 100%;
    border-radius: 0;
  }
  @media (min-width: 720px) {
    .tm-auth-dialog {
      width: 420px;
      max-width: 95vw;
      height: min(720px, 95vh);
      border-radius: 16px;
    }
  }
  .tm-auth-bar {
    background: #1f2937;
    color: #ffffff;
    flex: 0 0 auto;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tm-auth-bar .tm-auth-title {
    flex: 1;
    font-weight: 700;
    font-size: 14px;
  }
  .tm-auth-back-btn {
    order: -1;
  }
  .tm-auth-body {
    flex: 1 1 auto;
    padding: 16px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tm-auth-step {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1 1 auto;
    min-height: 0;
  }
  .tm-auth-desc {
    margin: 0;
    font-size: 13px;
    color: var(--text2);
    line-height: 1.5;
  }
  .tm-auth-search {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 16px;
    background: #ffffff;
    font-family: var(--font);
  }
  .tm-auth-search:focus {
    outline: none;
    border-color: #66aaff;
  }
  .tm-auth-list {
    flex: 1 1 auto;
    overflow-y: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #fafbfd;
    display: flex;
    flex-direction: column;
  }
  .tm-auth-item {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 10px;
    align-items: center;
    padding: 10px 12px;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    font-family: var(--font);
    color: var(--text);
  }
  .tm-auth-item:last-child {
    border-bottom: 0;
  }
  .tm-auth-item:hover {
    background: #eef2f7;
  }
  .tm-auth-item-photo,
  .tm-auth-item-photo-empty {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    flex-shrink: 0;
    object-fit: cover;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #dbe6f3, #eef3f9);
    color: #4a6080;
    font-weight: 700;
    font-size: 14px;
  }
  .tm-auth-item-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 2px;
  }
  .tm-auth-item-name {
    font-weight: 700;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .tm-auth-item-id {
    font-size: 11px;
    color: var(--text3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .tm-auth-empty {
    padding: 20px;
    text-align: center;
    color: var(--text3);
    font-size: 12px;
  }
  .tm-auth-selected {
    background: #ecfdf5;
    border: 1px solid #a7e9c5;
    color: #0e6d3a;
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
  }
  .tm-auth-pin-prompt {
    margin: 8px 0 0;
    text-align: center;
    color: var(--text);
    font-size: 14px;
    font-weight: 600;
  }
  .tm-pin-wrap {
    position: relative;
    display: flex;
    justify-content: center;
    margin: 4px auto;
    width: fit-content;
    cursor: text;
  }
  .tm-pin-input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    border: 0;
    outline: none;
    font-size: 16px;
    color: transparent;
    caret-color: transparent;
    text-align: center;
    letter-spacing: 0;
  }
  .tm-pin-boxes {
    display: flex;
    gap: 10px;
    pointer-events: none;
  }
  .tm-pin-box {
    width: 48px;
    height: 56px;
    border: 2px solid var(--border);
    border-radius: 10px;
    background: #fafbfd;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--text);
    font-weight: 700;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .tm-pin-box.tm-pin-box-filled {
    border-color: #66aaff;
    background: #ffffff;
    color: #1f2937;
  }
  .tm-pin-input:focus + .tm-pin-boxes .tm-pin-box.tm-pin-box-active {
    border-color: #66aaff;
  }
  .tm-auth-msg {
    min-height: 18px;
    text-align: center;
    font-size: 12px;
    color: #c0392b;
    line-height: 1.4;
  }

  @media (max-width: 720px) {
    .tm-auth-body {
      padding: 14px;
      gap: 10px;
    }
    .tm-pin-box {
      width: 44px;
      height: 52px;
      font-size: 22px;
    }
  }

  /* 다이얼로그 헤더 닫기/뒤로 버튼 — 비-미니게임 페이지 (가이드/이벤트/관리)에서도 동일하게 적용 */
  .tm-dlg-close-btn {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: 0;
    border-radius: 6px;
    width: 32px;
    height: 32px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.12s ease;
  }
  .tm-dlg-close-btn:hover {
    background: rgba(255, 255, 255, 0.22);
  }
</style>
