---
// 헤더 우측 인증 위젯.
// 비로그인: "로그인" 버튼.
// 로그인 (데스크톱): [아바타] [닉네임] [💎 N] [로그아웃] 가로 펼침.
// 로그인 (모바일): [아바타] [💎 N] ▾ — 클릭 시 닉네임 + 로그아웃 드롭다운.
//
// 동작 로직: src/scripts/components/logined-user-info.ts
// AuthDialog 가 BaseLayout 에 마운트돼있어야 ensureAuth 가 작동함.
---

<div class="hu" id="hu-root" data-state="loading">
  <!-- 스켈레톤: SSR 시점에 레이아웃 즉시 확정. JS hydrate 직후 loggedin/loggedout 으로 swap. -->
  <div class="hu-skeleton" aria-hidden="true">
    <span class="hu-sk-avatar"></span>
    <span class="hu-sk-line hu-sk-name"></span>
    <span class="hu-sk-line hu-sk-crystal"></span>
  </div>

  <button class="hu-login" id="hu-login" type="button" data-i18n="common.login">로그인</button>

  <div class="hu-card" id="hu-card">
    <button
      class="hu-trigger"
      id="hu-trigger"
      type="button"
      aria-haspopup="menu"
      aria-expanded="false"
    >
      <span class="hu-avatar" id="hu-avatar" aria-hidden="true">
        <img id="hu-avatar-img" alt="" />
        <span id="hu-avatar-initial" class="hu-avatar-initial"></span>
      </span>
      <span class="hu-name" id="hu-name">-</span>
      <span class="hu-crystal" aria-label="크리스탈 잔액" data-i18n-attr-aria-label="userMenu.crystalAria">
        <span class="hu-crystal-icon">💎</span>
        <span class="hu-crystal-value" id="hu-crystal-value">0</span>
      </span>
      <svg
        class="hu-caret"
        width="10"
        height="10"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>

    <button class="hu-logout-desktop" id="hu-logout-desktop" type="button" data-i18n="common.logout">로그아웃</button>

    <div class="hu-dropdown" id="hu-dropdown" role="menu" hidden>
      <div class="hu-dropdown-name" id="hu-dropdown-name">-</div>
      <button
        class="hu-dropdown-logout"
        id="hu-logout-mobile"
        type="button"
        role="menuitem"
        data-i18n="common.logout"
      >
        로그아웃
      </button>
    </div>
  </div>
</div>

<script>
  import '@/scripts/components/logined-user-info';
</script>

<style>
  .hu {
    margin-left: auto;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    position: relative;
    /* 로그인/비로그인/로딩 상태가 같은 폭을 점유하도록 reserve.
       로그인 카드 (avatar + 닉네임 + 크리스탈 + 로그아웃) 의 자연 폭 기준. */
    min-width: 240px;
  }

  /* 상태별 표시 — 한 시점에 셋 중 하나만 노출 */
  .hu[data-state='loading'] .hu-login,
  .hu[data-state='loading'] .hu-card,
  .hu[data-state='loggedout'] .hu-skeleton,
  .hu[data-state='loggedout'] .hu-card,
  .hu[data-state='loggedin'] .hu-skeleton,
  .hu[data-state='loggedin'] .hu-login {
    display: none;
  }

  /* === 스켈레톤 (SSR 직후 ~ JS hydrate 사이에만 보임) === */
  .hu-skeleton {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hu-sk-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.13);
    animation: huPulse 1.4s ease-in-out infinite;
  }
  .hu-sk-line {
    height: 11px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.13);
    animation: huPulse 1.4s ease-in-out infinite;
  }
  .hu-sk-name {
    width: 72px;
  }
  .hu-sk-crystal {
    width: 50px;
  }
  @keyframes huPulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 0.95; }
  }

  /* === 비로그인: 로그인 버튼 === */
  .hu-login {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    border-radius: 999px;
    padding: 5px 14px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    line-height: 1.4;
    transition: background 0.15s;
  }
  .hu-login:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* === 로그인 카드 === */
  .hu-card {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hu-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(99, 102, 241, 0.18);
    border: 1px solid rgba(165, 180, 252, 0.45);
    color: #fff;
    padding: 3px 10px 3px 3px;
    border-radius: 999px;
    cursor: default;
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
  }

  .hu-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    overflow: hidden;
    flex-shrink: 0;
  }
  .hu-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }
  .hu-avatar img.loaded {
    display: block;
  }
  .hu-avatar-initial {
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .hu-avatar.has-img .hu-avatar-initial {
    display: none;
  }

  /* 가로 나열 요소들의 수직 중앙 정렬 — 자식 모두 inline-flex + line-height: 1 통일 */
  .hu-name,
  .hu-crystal,
  .hu-crystal-icon,
  .hu-crystal-value {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  .hu-name {
    white-space: nowrap;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    /* ellipsis 가 작동하려면 inline-flex 위에 block-level overflow 가 필요 → display 만 block 으로 덮음 */
    display: inline-block;
    line-height: 1;
    vertical-align: middle;
  }
  .hu-crystal {
    gap: 4px;
    padding-left: 6px;
    border-left: 1px solid rgba(255, 255, 255, 0.18);
  }
  .hu-crystal-icon {
    font-size: 13px;
    /* 💎 이모지 광학 중심 보정 — 텍스트 baseline 보다 살짝 아래에 오는 글리프 특성 */
    transform: translateY(-0.5px);
  }
  .hu-crystal-value {
    font-variant-numeric: tabular-nums;
    min-width: 3.5em;
    justify-content: flex-end;
  }

  .hu-caret {
    display: none;
    color: rgba(255, 255, 255, 0.7);
  }

  .hu-logout-desktop {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.85);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    line-height: 1.4;
    transition: all 0.15s;
  }
  .hu-logout-desktop:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }

  /* === 모바일 드롭다운 (기본 숨김) === */
  .hu-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 180px;
    background: #2a2f36;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    padding: 10px;
    display: none;
    flex-direction: column;
    gap: 8px;
    z-index: 200;
  }
  .hu-dropdown[data-open='true'] {
    display: flex;
  }
  .hu-dropdown-name {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    padding: 4px 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    word-break: break-all;
  }
  .hu-dropdown-logout {
    background: rgba(239, 68, 68, 0.16);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    line-height: 1.4;
  }
  .hu-dropdown-logout:hover {
    background: rgba(239, 68, 68, 0.28);
    color: #fff;
  }

  /* === 모바일 (≤768px): 닉네임/데스크톱 로그아웃 숨김, caret 표시, 트리거 클릭 → 드롭다운 === */
  @media (max-width: 768px) {
    .hu-name {
      display: none;
    }
    .hu-logout-desktop {
      display: none;
    }
    .hu-caret {
      display: inline-block;
    }
    .hu-trigger {
      padding: 2px 8px 2px 2px;
      font-size: 12px;
      cursor: pointer;
      transition: background 0.15s;
    }
    .hu-trigger:hover {
      background: rgba(99, 102, 241, 0.28);
    }
    .hu-avatar {
      width: 24px;
      height: 24px;
    }
    .hu-login {
      padding: 4px 12px;
      font-size: 12px;
    }
    .hu {
      /* 모바일은 컴팩트 — 로그인 버튼 / 카드 폭 차이가 작아서 reserve 적게 */
      min-width: 90px;
    }
  }
</style>
