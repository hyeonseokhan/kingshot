---
import BaseLayout from './BaseLayout.astro';
import LeftNav from '@/components/LeftNav.astro';
import RightToc from '@/components/RightToc.astro';

interface Props {
  title?: string;
  description?: string;
  navHeader: string;
  navItems: Array<{ title: string; path: string; active?: boolean }>;
}

const { title, description, navHeader, navItems } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="tab-content active">
    <LeftNav header={navHeader} items={navItems} />
    <main class="center-content">
      <div class="section-content">
        <slot />
      </div>
    </main>
    <RightToc />
  </div>
</BaseLayout>

<style>
  .tab-content {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  .center-content {
    flex: 1;
    overflow-y: auto;
    padding: 32px 48px 80px;
    min-width: 0;
  }
  .center-content :global(.section-content) {
    max-width: 720px;
    margin: 0 auto;
    animation: fadeIn 0.15s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .center-content {
      padding: 24px 32px 60px;
    }
  }
  @media (max-width: 768px) {
    .center-content {
      padding: 16px 14px 80px;
    }
    .center-content :global(.section-content) {
      max-width: 100%;
    }
  }
</style>
