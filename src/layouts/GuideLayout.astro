---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import LeftNav from '@/components/LeftNav.astro';
import RightToc from '@/components/RightToc.astro';

interface Props {
  title?: string;
  description?: string;
  navHeader: string;
  navItems: Array<{ title: string; path: string; active?: boolean }>;
  headings?: MarkdownHeading[];
}

const { title, description, navHeader, navItems, headings = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="tab-content active">
    <LeftNav header={navHeader} items={navItems} />
    <main class="center-content">
      <div class="section-content">
        <slot />
      </div>
    </main>
    <RightToc headings={headings} />
  </div>
</BaseLayout>

<script>
  // 마크다운 본문 H2/H3/H4 앞에 # 앵커를 부여 (호버 시 표시).
  function attachAnchors() {
    const section = document.querySelector('.section-content');
    if (!section) return;
    const headings = section.querySelectorAll<HTMLHeadingElement>(
      'h2[id], h3[id], h4[id]',
    );
    for (const h of headings) {
      if (h.querySelector('.heading-anchor')) continue;
      const a = document.createElement('a');
      a.className = 'heading-anchor';
      a.href = `#${h.id}`;
      a.textContent = '#';
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const center = h.closest<HTMLElement>('.center-content');
        if (center) {
          center.scrollTo({ top: h.offsetTop - 60, behavior: 'smooth' });
        }
        history.replaceState(null, '', `#${h.id}`);
      });
      h.insertBefore(a, h.firstChild);
    }
  }

  // 페이지 진입 시 hash 가 있으면 해당 heading 으로 스크롤.
  function scrollToInitialHash() {
    if (!location.hash) return;
    const id = decodeURIComponent(location.hash.slice(1));
    const el = document.getElementById(id);
    const center = document.querySelector<HTMLElement>('.center-content');
    if (!el || !center) return;
    const doScroll = () => center.scrollTo({ top: el.offsetTop - 20, behavior: 'instant' });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(() => setTimeout(doScroll, 50));
    } else {
      setTimeout(doScroll, 200);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      attachAnchors();
      scrollToInitialHash();
    });
  } else {
    attachAnchors();
    scrollToInitialHash();
  }
</script>

<style>
  .tab-content {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  .center-content {
    flex: 1;
    overflow-y: auto;
    padding: 32px 48px 80px;
    min-width: 0;
  }
  .center-content :global(.section-content) {
    max-width: 720px;
    margin: 0 auto;
    animation: fadeIn 0.15s ease;
  }

  /* 마크다운 본문 — Astro <Content> 가 렌더하므로 :global() 필수 */
  .center-content :global(h1) {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.3;
  }
  .center-content :global(h2) {
    font-size: 1.35rem;
    font-weight: 650;
    margin: 36px 0 14px;
    padding-top: 20px;
    border-top: 1px solid var(--border2);
    color: var(--text);
    letter-spacing: -0.01em;
    position: relative;
  }
  .center-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 28px 0 10px;
    color: var(--text);
    position: relative;
  }
  .center-content :global(h4) {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 22px 0 8px;
    color: var(--text2);
    position: relative;
  }
  .center-content :global(p) {
    margin: 0 0 12px;
    color: var(--text);
  }
  .center-content :global(ul),
  .center-content :global(ol) {
    margin: 0 0 14px;
    padding-left: 24px;
  }
  .center-content :global(li) {
    margin: 3px 0;
    color: var(--text);
  }
  .center-content :global(li + li) {
    margin-top: 4px;
  }
  .center-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border2);
    margin: 28px 0;
  }
  .center-content :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--bg2);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--red);
  }
  .center-content :global(pre) {
    margin: 14px 0;
    border-radius: 8px;
    border: 1px solid var(--border2);
    overflow-x: auto;
    background: #f6f8fa;
    padding: 14px 16px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.55;
  }
  .center-content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .center-content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 8px 0;
  }
  .center-content :global(blockquote) {
    margin: 14px 0;
    padding: 12px 16px;
    background: var(--accent-bg);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    font-size: 0.92em;
    color: var(--text);
  }
  .center-content :global(blockquote p) {
    margin: 0 0 6px;
  }
  .center-content :global(blockquote p:last-child) {
    margin: 0;
  }
  .center-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88em;
    margin: 14px 0;
    border-radius: 8px;
    border: 1px solid var(--border2);
    overflow: hidden;
  }
  .center-content :global(th) {
    background: var(--bg2);
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    border-bottom: 1px solid var(--border);
  }
  .center-content :global(td) {
    padding: 9px 14px;
    border-bottom: 1px solid var(--border2);
    vertical-align: top;
  }
  .center-content :global(tr:last-child td) {
    border-bottom: none;
  }
  .center-content :global(tbody tr:hover) {
    background: var(--bg2);
  }

  /* heading anchor (#) — 호버 시 노출 */
  .center-content :global(.heading-anchor) {
    position: absolute;
    left: -1.3em;
    font-size: 0.85em;
    color: var(--text3);
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.15s;
    font-weight: 400;
  }
  .center-content :global(h2:hover .heading-anchor),
  .center-content :global(h3:hover .heading-anchor),
  .center-content :global(h4:hover .heading-anchor) {
    opacity: 1;
  }
  .center-content :global(.heading-anchor:hover) {
    color: var(--accent);
    text-decoration: none;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .center-content {
      padding: 24px 32px 60px;
    }
  }
  @media (max-width: 768px) {
    .center-content {
      padding: 16px 14px 80px;
    }
    .center-content :global(.section-content) {
      max-width: 100%;
    }
    .center-content :global(h1) {
      font-size: 1.3rem;
      margin-bottom: 14px;
    }
    .center-content :global(h2) {
      font-size: 1.1rem;
      margin: 24px 0 10px;
      padding-top: 14px;
    }
    .center-content :global(h3) {
      font-size: 0.95rem;
      margin: 18px 0 8px;
    }
    .center-content {
      font-size: 14px;
      line-height: 1.8;
    }
    .center-content :global(p),
    .center-content :global(li) {
      word-break: keep-all;
    }
    .center-content :global(blockquote) {
      padding: 10px 12px;
      font-size: 0.88em;
    }
    .center-content :global(pre) {
      font-size: 12px;
      padding: 10px 12px;
    }
    .center-content :global(table) {
      font-size: 0.82em;
      width: 100%;
      display: table;
      overflow-x: auto;
    }
    .center-content :global(th) {
      padding: 8px 10px;
    }
    .center-content :global(td) {
      padding: 7px 10px;
      white-space: normal;
      word-break: keep-all;
    }
    .center-content :global(ul) {
      padding-left: 18px;
    }
    .center-content :global(ol) {
      padding-left: 20px;
    }
    .center-content :global(hr) {
      margin: 20px 0;
    }
  }
</style>
