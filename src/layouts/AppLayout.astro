---
import BaseLayout from './BaseLayout.astro';
import LeftNav from '@/components/LeftNav.astro';

interface Props {
  title?: string;
  description?: string;
  navHeader: string;
  navItems: Array<{ title: string; path: string; active?: boolean }>;
}

const { title, description, navHeader, navItems } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="tab-content active">
    <LeftNav header={navHeader} items={navItems} />
    <main class="center-content manage-content">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .tab-content {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  .center-content {
    flex: 1;
    overflow-y: auto;
    padding: 32px 48px 80px;
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .center-content {
      padding: 24px 32px 60px;
    }
  }
  @media (max-width: 768px) {
    .center-content {
      padding: 12px 14px 80px;
    }
  }
</style>
