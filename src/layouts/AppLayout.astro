---
import BaseLayout from './BaseLayout.astro';
import LeftNav from '@/components/LeftNav.astro';

interface Props {
  title?: string;
  description?: string;
  navHeader: string;
  navItems: Array<{ title: string; path: string; active?: boolean }>;
}

const { title, description, navHeader, navItems } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="tab-content active">
    <LeftNav header={navHeader} items={navItems} />
    <main class="center-content manage-content">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  /* .center-content padding 은 components.css 에서 일괄 정의 (BaseLayout 글로벌).
     scoped 와의 specificity 충돌 방지를 위해 layout 자체는 flex 골격만 처리. */
  .tab-content {
    display: flex;
    flex: 1;
    overflow: hidden;
  }
</style>
